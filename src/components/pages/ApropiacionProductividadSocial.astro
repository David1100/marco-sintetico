<style>
  .aps-shell {
    background-image: radial-gradient(circle at 20% 20%, rgba(181, 227, 208, 0.4), transparent 55%),
      radial-gradient(circle at 80% 0%, rgba(255, 206, 173, 0.35), transparent 45%),
      linear-gradient(135deg, #f8fbff 0%, #f0f4f2 50%, #f9f6f1 100%);
    animation: apsGradientShift 22s ease-in-out infinite alternate;
  }

  .aps-topbar {
    animation: apsSlideDown 0.85s cubic-bezier(0.215, 0.61, 0.355, 1) both;
  }

  .aps-sidebar {
    animation: apsSlideRight 1s cubic-bezier(0.33, 1, 0.68, 1) 0.1s both;
    box-shadow: 30px 0 60px rgba(15, 68, 52, 0.05);
  }

  .aps-nav-item {
    position: relative;
    overflow: hidden;
    transition: transform 0.4s ease, color 0.3s ease;
  }

  .aps-nav-item::after {
    content: "";
    position: absolute;
    inset: auto 1.25rem 0 1.25rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, currentColor, transparent);
    opacity: 0;
    transform: scaleX(0.5);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .aps-nav-item:hover {
    transform: translateX(6px);
  }

  .aps-nav-item:hover::after {
    opacity: 0.8;
    transform: scaleX(1);
  }

  .aps-hero {
    animation: apsFadeUp 0.9s ease 0.2s both;
  }

  .aps-radiant-panel {
    position: relative;
    animation: apsPulse 12s ease-in-out infinite;
    overflow: hidden;
  }

  .aps-radiant-panel::before {
    content: "";
    position: absolute;
    inset: 10%;
    border-radius: 40px;
    background: radial-gradient(circle, rgba(31, 123, 92, 0.12), transparent 60%);
    filter: blur(40px);
    z-index: 0;
    animation: apsGlow 8s ease-in-out infinite alternate;
  }

  .aps-radiant-panel > div {
    position: relative;
    z-index: 2;
  }

  .aps-system {
    position: relative;
    padding: clamp(2rem, 4vw, 4rem) clamp(1rem, 6vw, 4rem) 3.5rem;
  }

  .aps-arcs {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.9;
  }

  .aps-arc {
    fill: none;
    stroke-linecap: round;
    stroke-width: 3;
    stroke-dasharray: 16 9;
    animation: apsFlowDash 18s linear infinite;
  }

  .aps-arc--top {
    stroke: var(--color-primary);
    animation-duration: 20s;
  }

  .aps-arc--middle {
    stroke: var(--color-secondary);
    stroke-dasharray: 12 6;
    animation-duration: 12s;
  }

  .aps-arc--bottom {
    stroke: var(--color-tertiary);
    animation-duration: 22s;
  }

  .aps-spark {
    position: absolute;
    width: 140px;
    height: 140px;
    border-radius: 9999px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.8), transparent 70%);
    mix-blend-mode: screen;
    opacity: 0.25;
    animation: apsSparkPulse 6s ease-in-out infinite, apsSparkTravel 18s linear infinite;
    pointer-events: none;
    z-index: 1;
  }

  .aps-spark::after {
    content: "";
    position: absolute;
    inset: 20%;
    border-radius: inherit;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .aps-spark-one {
    top: 12%;
    left: 18%;
  }

  .aps-spark-two {
    top: 58%;
    left: 64%;
    width: 110px;
    height: 110px;
    animation-delay: 1s, 2s;
  }

  .aps-spark-three {
    top: 32%;
    left: 80%;
    width: 90px;
    height: 90px;
    animation-delay: 0.5s, 3s;
  }

  .aps-node-row {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .aps-node-row {
      flex-direction: row;
      align-items: flex-start;
      justify-content: center;
      gap: 3rem;
    }
  }

  .aps-node-card {
    width: 100%;
    max-width: 260px;
    text-align: center;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.72));
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 1.75rem;
    padding: 1.5rem;
    box-shadow: 0 20px 50px rgba(18, 60, 49, 0.08);
    backdrop-filter: blur(6px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.45s ease, box-shadow 0.45s ease;
  }

  .aps-node-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 25px 70px rgba(18, 60, 49, 0.15);
  }

  .aps-node-card--center {
    max-width: 320px;
    padding: 1.75rem;
    border-width: 2px;
  }

  .aps-node-figure {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 1.25rem;
    overflow: hidden;
    border: 4px solid rgba(33, 122, 93, 0.1);
  }

  .aps-node-card--center .aps-node-figure {
    border-color: rgba(253, 138, 66, 0.15);
  }

  .aps-node-figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .aps-node-card:hover .aps-node-figure img {
    transform: scale(1.05);
  }

  .aps-node-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .aps-node-label {
    font-family: var(--font-headline);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .aps-node-sub {
    font-size: 0.85rem;
    color: var(--color-on-surface-variant);
  }

  .aps-node-chip {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 0.45rem 1.5rem;
    border-radius: 9999px;
    background: rgba(0, 71, 47, 0.08);
    color: var(--color-on-surface);
  }

  .aps-node-chip--secondary {
    background: rgba(253, 138, 66, 0.12);
    color: var(--color-secondary);
  }

  .aps-node-chip--tertiary {
    background: rgba(71, 85, 106, 0.12);
    color: var(--color-tertiary);
  }

  .aps-productividad-tag {
    margin-top: 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-family: var(--font-label);
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-size: 0.75rem;
    color: var(--color-on-surface-variant);
  }

  .aps-productividad-tag span {
    font-weight: 700;
    color: var(--color-primary);
  }

  .aps-card,
  .aps-panorama {
    opacity: 0;
    transform: translateY(30px);
    animation: apsFloatUp 1s ease forwards;
  }

  .aps-panorama::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.4), transparent 55%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .aps-panorama:hover::after {
    opacity: 1;
  }

  .aps-panorama img {
    transition: transform 8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .aps-panorama:hover img {
    transform: scale(1.15);
  }

  .aps-bottom-nav {
    backdrop-filter: blur(20px);
    animation: apsFadeUp 0.8s ease 0.3s both;
  }

  .aps-bottom-nav span {
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .aps-bottom-nav span:hover {
    transform: translateY(-4px) scale(1.1);
    color: var(--color-primary);
  }

  @keyframes apsSlideDown {
    from {
      transform: translateY(-30px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes apsSlideRight {
    from {
      transform: translateX(-30px);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes apsFadeUp {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes apsFloatUp {
    from {
      transform: translateY(35px) scale(0.98);
      opacity: 0;
    }
    to {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }

  @keyframes apsPulse {
    0% {
      box-shadow: 0 20px 60px rgba(32, 95, 68, 0.08);
    }
    100% {
      box-shadow: 0 30px 80px rgba(32, 95, 68, 0.15);
    }
  }

  @keyframes apsGlow {
    from {
      opacity: 0.4;
    }
