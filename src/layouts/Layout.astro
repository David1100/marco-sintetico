---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html class="light" lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />

    <!-- Material Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="font-body text-on-surface min-h-screen">
    <button id="audio-toggle" class="fixed bottom-4 right-4 z-50 bg-primary text-white p-3 rounded-full shadow-lg hover:bg-primary/90 transition-colors" aria-label="Activar audio">
      <span class="material-symbols-outlined">volume_up</span>
    </button>
    <audio id="bg-audio" loop src="/audio.mp3"></audio>
    <script>
      const audio = document.getElementById('bg-audio');
      const btn = document.getElementById('audio-toggle');
      let playing = false;
      btn.addEventListener('click', () => {
        if (playing) {
          audio.pause();
          btn.innerHTML = '<span class="material-symbols-outlined">volume_off</span>';
        } else {
          audio.play();
          btn.innerHTML = '<span class="material-symbols-outlined">volume_up</span>';
        }
        playing = !playing;
      });
    </script>
    <video autoplay loop muted playsinline class="fixed inset-0 w-full h-full object-cover -z-10 pointer-events-none">
      <source src="/images/fondo.mp4" type="video/mp4" />
    </video>
    <div class="fixed inset-0 bg-gradient-to-br from-amber-950/40 via-amber-900/20 to-amber-950/40 pointer-events-none -z-10"></div>

    <header class="fixed top-0 left-0 right-0 z-50 bg-white/70 backdrop-blur-md border-b border-amber-900/20 h-16 flex items-center px-8 shadow-lg">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-2xl">eco</span>
        <a href="/" class="font-headline font-extrabold text-primary text-xl tracking-tight">
          Marco Sintético
        </a>
      </div>
      <div class="ml-auto flex flex-col items-end">
        <span class="font-headline text-sm text-secondary font-bold">JORGE CADENA CUEVAS</span>
      </div>
    </header>

    <div class="fixed top-16 left-0 right-0 z-40 bg-gradient-to-r from-amber-50/80 via-amber-100/60 to-amber-50/80 border-b border-amber-900/10 py-2 text-center">
      <span class="font-headline text-lg text-secondary font-semibold tracking-wide">AMOR EFICAZ Y SINCERO</span>
    </div>

    <main class="pt-24 min-h-screen pb-20">
      <div class="max-w-7xl mx-auto p-8">
        <slot />
      </div>
    </main>

    <footer class="fixed bottom-0 left-0 right-0 z-40 bg-white/60 backdrop-blur-sm border-t border-amber-900/10 py-3 text-center">
      <div class="flex flex-col items-center">
        <span class="font-headline text-base text-secondary font-bold tracking-wide">PAZ, LIBERTAD, VIDA Y AMOR.</span>
        <div class="mt-1 flex flex-col sm:flex-row sm:gap-4 text-[10px] sm:text-xs text-on-surface-variant">
          <span>Forme Equipo Trabajo Fundación</span>
          <span>Economista y Especialista Salud Ocupacional</span>
          <span>Director-Investigador: Dr. GERMÁN ZABALA CUBILLOS</span>
          <span>Matemático - Fundación Latinoamericana Investigación y Formación Social</span>
        </div>
      </div>
    </footer>
  </body>
</html>
