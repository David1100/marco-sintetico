---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Reciclaje Cibernético - Ecosistema de Productividad Social">
  <!-- Hero Section -->
  <section class="mb-16 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    <div class="lg:col-span-7 animate-slide-up" style="animation-delay: 0s; opacity: 0;">
      <span class="text-secondary font-body font-semibold tracking-widest uppercase text-xs mb-4 block">Visión Técnica Estratégica</span>
      <h2 class="text-4xl md:text-6xl font-body font-extrabold text-primary leading-[1.1] mb-8 tracking-tight">
        Transformación de la <span class="text-secondary">Materia Prima</span> en Capital Social.
      </h2>
      <p class="text-lg text-on-surface-variant leading-relaxed max-w-2xl font-light">
        Un análisis exhaustivo sobre la optimización de procesos técnicos aplicados a la diversificación de recursos, superando las barreras bióticas y tecnológicas para alcanzar la máxima eficiencia productiva.
      </p>
    </div>
    <div class="lg:col-span-5 flex flex-col gap-6 animate-slide-up" style="animation-delay: 0.1s; opacity: 0;">
      <!-- Sidebar Technical Notes -->
      <div class="glass-card p-8 rounded-[2rem] border-l-4 border-primary">
        <h3 class="text-sm font-body font-bold text-primary mb-4 uppercase tracking-widest">Protocolos de Gobernanza</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-on-surface-variant font-medium">
            <span class="w-1.5 h-1.5 bg-secondary rounded-full"></span> Cibernética Cultural: tiempo libre
          </li>
          <li class="flex items-center gap-3 text-on-surface-variant font-medium">
            <span class="w-1.5 h-1.5 bg-secondary rounded-full"></span> Apropiación del ocio creador
          </li>
          <li class="flex items-center gap-3 text-on-surface-variant font-medium">
            <span class="w-1.5 h-1.5 bg-secondary rounded-full"></span> Red de Relaciones Sociales
          </li>
          <li class="flex items-center gap-3 text-on-surface-variant font-medium">
            <span class="w-1.5 h-1.5 bg-secondary rounded-full"></span> La distribución de la fiesta
          </li>
          <li class="flex items-center gap-3 text-on-surface-variant font-medium">
            <span class="w-1.5 h-1.5 bg-secondary rounded-full"></span> La regulación Invisible
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Technical Modules Bento Grid -->
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
    <!-- Section 1: Diversificación Técnica -->
    <div class="md:col-span-8 group animate-slide-up" style="animation-delay: 0.2s; opacity: 0;">
      <div class="relative h-[400px] md:h-[500px] overflow-hidden rounded-[2rem] bg-surface-container-lowest shadow-sm hover:shadow-lg transition-all duration-500">
        <img alt="Piña Realista" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="/images/reciclaje-cibernetico/diversificacion_tecnica.png" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
        <div class="absolute bottom-10 left-10 right-10">
          <span class="text-primary-fixed font-body text-xs uppercase tracking-widest font-bold bg-primary px-3 py-1 rounded-full inline-block mb-4">Módulo 01</span>
          <h3 class="text-2xl md:text-3xl font-body font-bold text-white mb-2">Diversificación Técnica</h3>
          <p class="text-primary-fixed-dim text-lg">- PARA APROVECHAMIENTO TOTAL DEL PRODUCTO</p>
        </div>
      </div>
    </div>

    <!-- Section 2: Aprovechamiento Físico-Químico -->
    <div class="md:col-span-4 group animate-slide-up" style="animation-delay: 0.3s; opacity: 0;">
      <div class="relative h-[400px] md:h-[500px] overflow-hidden rounded-[2rem] bg-surface-container-lowest shadow-sm">
        <img alt="Laboratorio" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" src="/images/reciclaje-cibernetico/aprovechamiento_quimico.png" />
        <div class="absolute inset-0 bg-gradient-to-t from-tertiary/90 via-tertiary/20 to-transparent"></div>
        <div class="absolute bottom-10 left-8 right-8">
          <span class="text-tertiary-fixed font-body text-xs uppercase tracking-widest font-bold bg-tertiary px-3 py-1 rounded-full inline-block mb-4">Módulo 02</span>
          <h3 class="text-xl md:text-2xl font-body font-bold text-white mb-2">Análisis Físico-Químico</h3>
          <p class="text-tertiary-fixed-dim text-sm">- SUPERAR LA BARRERA BIÓTICA</p>
        </div>
      </div>
    </div>

    <!-- Section 3: Maximización Tecnológica -->
    <div class="md:col-span-4 group animate-slide-up" style="animation-delay: 0.4s; opacity: 0;">
      <div class="relative h-[350px] md:h-[450px] overflow-hidden rounded-[2rem] bg-surface-container-highest">
        <img alt="Computador Moderno" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" src="/images/reciclaje-cibernetico/maximizacion_tecnologica.png" />
        <div class="absolute inset-0 bg-primary/20 group-hover:bg-transparent transition-colors"></div>
        <div class="absolute inset-0 p-8 flex flex-col justify-end">
          <h3 class="text-xl md:text-2xl font-body font-bold text-on-surface mb-2">Maximización Tecnológica</h3>
          <p class="text-on-surface-variant font-medium">- DIFERENCIACIÓN DE ASPECTOS</p>
        </div>
      </div>
    </div>

    <!-- Section 4: Abaratamiento del Transporte -->
    <div class="md:col-span-5 group animate-slide-up" style="animation-delay: 0.5s; opacity: 0;">
      <div class="relative h-[350px] md:h-[450px] overflow-hidden rounded-[2rem] bg-surface-container-low border border-outline-variant/10">
        <img alt="Transporte Moderno" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" src="/images/reciclaje-cibernetico/abaratamiento_transporte.png" />
        <div class="absolute inset-0 bg-secondary/10"></div>
        <div class="absolute bottom-10 left-10 right-10 glass-card p-6 rounded-xl">
          <h3 class="text-xl font-body font-bold text-on-secondary-container">Abaratamiento del Transporte</h3>
          <p class="text-secondary font-semibold text-sm">- LAS DISTANCIAS SE ACORTARON</p>
        </div>
      </div>
    </div>

    <!-- Section 5: Minimización del Gasto de Energía -->
    <div class="md:col-span-3 group animate-slide-up" style="animation-delay: 0.6s; opacity: 0;">
      <div class="relative h-[350px] md:h-[450px] overflow-hidden rounded-[2rem] bg-stone-900 flex items-center justify-center">
        <div class="absolute inset-0 opacity-40">
          <img alt="Energía" class="w-full h-full object-cover" src="/images/reciclaje-cibernetico/minimizado_energia.png" />
        </div>
        <div class="relative z-10 text-center p-6">
          <span class="material-symbols-outlined text-secondary-container text-5xl mb-4 block">electric_bolt</span>
          <h3 class="text-xl font-body font-bold text-white mb-2">Gasto de Energía</h3>
          <p class="text-emerald-400 text-xs font-body uppercase tracking-widest">- DISTINTAS ALTERNATIVAS</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Technical Deep Dive -->
  <section class="glass-card p-12 md:p-16 mb-16 rounded-[2rem] relative overflow-hidden animate-slide-up" style="animation-delay: 0.7s; opacity: 0;">
    <div class="absolute top-0 right-0 w-1/3 h-full opacity-10 pointer-events-none">
      <span class="material-symbols-outlined text-[200px] md:text-[300px] text-primary">eco</span>
    </div>
    <div class="max-w-3xl relative z-10">
      <h4 class="text-primary font-body text-2xl md:text-3xl font-bold mb-6">Eficiencia Metabólica del Sistema</h4>
      <p class="text-on-surface-variant text-lg leading-relaxed mb-8">
        La integración de estas cinco dimensiones permite una reducción del 40% en residuos bióticos y un incremento del 22% en la distribución de riqueza social a través de la red de relaciones.
      </p>
      <div class="flex flex-wrap gap-4">
        <div class="bg-white/50 backdrop-blur-md px-6 py-4 rounded-xl shadow-sm">
          <span class="block text-secondary font-bold text-2xl">98%</span>
          <span class="text-[10px] uppercase font-body text-on-surface-variant font-bold">Recuperación Pulpa</span>
        </div>
        <div class="bg-white/50 backdrop-blur-md px-6 py-4 rounded-xl shadow-sm">
          <span class="block text-primary font-bold text-2xl">0.02</span>
          <span class="text-[10px] uppercase font-body text-on-surface-variant font-bold">Coeficiente Gasto</span>
        </div>
        <div class="bg-white/50 backdrop-blur-md px-6 py-4 rounded-xl shadow-sm">
          <span class="block text-tertiary font-bold text-2xl">4.0</span>
          <span class="text-[10px] uppercase font-body text-on-surface-variant font-bold">Nivel Cibernético</span>
        </div>
      </div>
    </div>
  </section>

  <PageNav
    prev={{ href: "/reciclaje-residual", label: "Reciclaje", sublabel: "Residual" }}
    next={{ href: "/coordinacion-transformacion", label: "Coordinación", sublabel: "Transformación" }}
  />
</Layout>