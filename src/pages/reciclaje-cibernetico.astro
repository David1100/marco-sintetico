---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";

const blocks = [
  {
    title: "DIVERSIFICACION TECNICA:",
    subtitle: "-Para aprovechamiento total del producto",
    image: "/images/reciclaje-cibernetico/diversificacion_tecnica.png",
    imageAlt: "Diversificación Técnica",
    textTitle: "Cibernetico Cultural",
    textContent: "tiempo libre",
  },
  {
    title: "APROVECHAMIENTO FISICO-QUIMICO:",
    subtitle: "-SUPERAR LA BARRERA BIOTICA",
    image: "/images/reciclaje-cibernetico/aprovechamiento_quimico.png",
    imageAlt: "Diversificación Técnica",
    textTitle: "Apropiacion del ocio",
    textContent: "Creador",
  },
  {
    title: "MAXIMIZACION TECNOLOGICA:",
    subtitle: "-DIFERENCIACION DE ASPECTOS",
    image: "/images/reciclaje-cibernetico/maximizacion_tecnologica.png",
    imageAlt: "Diversificación Técnica",
    textTitle: "Red de Relaciones",
    textContent: "Sociales",
  },
  {
    title: "ABARATAMIENTO DEL TRANSPORTE:",
    subtitle: "-LAS DISTANCIAS SE ACORTARON",
    image: "/images/reciclaje-cibernetico/abaratamiento_transporte.png",
    imageAlt: "Diversificación Técnica",
    textTitle: "La distribución de la",
    textContent: "fiesta",
  },
  {
    title: "MINIMIZACION DE GASTOS DE ENERGIA:",
    subtitle: "-DISTINTAS ALTERNATIVAS",
    image: "/images/reciclaje-cibernetico/minimizado_energia.png",
    imageAlt: "Diversificación Técnica",
    textTitle: "La regulación Invisible",
    textContent: "",
  },
];
---

<Layout title="Reciclaje Cibernético - Ecosistema de Productividad Social">
  <!-- Audio: tiempo libre -->
  <audio id="tiempo-libre-audio" class="hidden" autoplay loop>
    <source src="/tiempolibre.mp3" type="audio/mpeg" />
  </audio>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const audio = document.getElementById(
        "tiempo-libre-audio",
      ) as HTMLAudioElement;
      if (audio) {
        audio.play().catch(() => {});
      }
    });
  </script>

  <h1 class="text-3xl md:text-4xl font-bold text-primary mb-12 text-center">RECICLAJE CIBERNÉTICO</h1>
  <div class="flex flex-col gap-y-2">
    {
      blocks.map((block) => (
        <div class="flex flex-col md:flex-row gap-8 items-stretch">
          <!-- Div 1: Título y Subtítulo -->
          <div class="md:w-1/2 flex flex-col justify-center items-center md:items-start text-center md:text-left p-8">
            <h1 class="text-xl md:text-3xl font-body font-extrabold text-primary tracking-tight mb-4">
              {block.title}
            </h1>
            <p class="text-md md:text-lg font-body text-secondary font-semibold">
              {block.subtitle}
            </p>
          </div>

          <!-- Div 2: Imagen + Texto -->
          <div class="md:w-1/2 flex flex-col md:flex-row gap-4">
            <!-- Imagen -->
            <div class="md:w-1/2">
              <img
                alt={block.imageAlt}
                src={block.image}
                class="w-full h-full rounded-2xl object-cover shadow-lg"
              />
            </div>
            <!-- Texto -->
            <div class="md:w-1/2 flex items-center justify-center">
              <div class="text-center md:text-left p-4">
                <h2 class="text-lg md:text-xl font-body font-bold text-primary">
                  {block.textTitle}
                </h2>
                <p class="text-lg font-body text-on-surface-variant">
                  {block.textContent}
                </p>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <PageNav
    prev={{
      href: "/tecnologia-punta-propia",
      label: "Tecnología",
      sublabel: "Punta",
    }}
    next={{
      href: "/coexistencia-pacifica",
      label: "Coexistencia",
      sublabel: "Pacífica",
    }}
  />
</Layout>
