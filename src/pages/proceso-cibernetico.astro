---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";

const arrowLabels = ["TELEMATICA", "PRIVATICA", "INFORMATICA"];
---

<Layout title="Página 19 - Proceso Cibernético">
  <article class="sheet relative overflow-hidden">
    <div class="sheet-grain" aria-hidden="true"></div>

    <header class="sheet-header animate-fade-in" style="animation-delay: 0s; opacity: 0;">
      <h1 class="sheet-title">Proceso Cibernético (Computación, Automatización, Robotización)</h1>
    </header>

    <section class="diagram animate-slide-up" style="animation-delay: 0.1s; opacity: 0;">
      <div class="diagram-grid">
        <div class="diagram-left">
          <div class="label-card">
            <p>Paradigma</p>
            <p>Microelectrónico</p>
          </div>
        </div>

        <div class="diagram-center">
          <div class="circle-frame animate-scale-in" style="animation-delay: 0.15s; opacity: 0;">
            <div class="circle-ring circle-ring--outer"></div>
            <div class="circle-ring circle-ring--inner"></div>
            <div class="circle-image" data-path="/images/pagina19/paradigma.png">
              <img src="/images/pagina19/paradigma.png" alt="Ilustración del paradigma microelectrónico" loading="lazy" decoding="async" onerror="this.remove();" />
            </div>
          </div>
          <p class="circle-caption">Tecnología Punta</p>
        </div>

        <div class="diagram-right">
          {arrowLabels.map((label, index) => (
            <div class="arrow-strip" style={`animation-delay: ${0.2 + index * 0.05}s;`}>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </article>

  <PageNav prev={{ href: "/social-poder-politico", label: "Espacio Social", sublabel: "Poder Político" }} next={{ href: "/practica-pervivencia", label: "Ciclo Económico", sublabel: "Producción" }} />

  <style>
    .sheet {
      background: radial-gradient(circle at top, rgba(255, 255, 255, 0.95), rgba(250, 242, 226, 0.92));
      border-radius: 2.75rem;
      padding: clamp(1.8rem, 5vw, 3.8rem);
      border: 1px solid rgba(44, 24, 16, 0.18);
      box-shadow: 0 25px 60px rgba(44, 24, 16, 0.15);
      position: relative;
    }

    .sheet-grain {
      position: absolute;
      inset: 0;
      background-image: repeating-linear-gradient(90deg, rgba(139, 69, 19, 0.04) 0, rgba(139, 69, 19, 0.04) 1px, transparent 1px, transparent 10px);
      opacity: 0.35;
      pointer-events: none;
      mix-blend-mode: multiply;
    }

    .sheet-title {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: clamp(1.5rem, 3.4vw, 2.6rem);
      letter-spacing: 0.02em;
      text-align: center;
      color: var(--color-primary);
    }

    .diagram {
      margin-top: clamp(1.5rem, 4vw, 3rem);
    }

    .diagram-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: clamp(1rem, 3vw, 2.5rem);
      align-items: center;
    }

    .diagram-left {
      display: flex;
      justify-content: center;
    }

    .label-card {
      display: inline-flex;
      flex-direction: column;
      gap: 0.4rem;
      padding: 1.75rem 1.5rem;
      border: 2px dashed rgba(44, 24, 16, 0.45);
      border-radius: 1.5rem;
      text-align: center;
      font-family: var(--font-body);
      letter-spacing: 0.05em;
      font-size: 0.95rem;
      background: rgba(255, 250, 240, 0.9);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.6);
    }

    .diagram-center {
      text-align: center;
      position: relative;
    }

    .circle-frame {
      width: min(360px, 90vw);
      max-width: 100%;
      aspect-ratio: 1 / 1;
      position: relative;
      margin: 0 auto;
    }

    .circle-ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px dashed rgba(44, 24, 16, 0.35);
      animation: slowSpin 18s linear infinite;
    }

    .circle-ring--outer {
      inset: -10px;
      border-style: dashed;
      opacity: 0.4;
    }

    .circle-ring--inner {
      inset: 14px;
      border-style: solid;
      opacity: 0.6;
      animation-direction: reverse;
    }

    .circle-image {
      position: absolute;
      inset: 32px;
      border-radius: 50%;
      overflow: hidden;
      border: 3px solid rgba(44, 24, 16, 0.35);
      background: rgba(255, 255, 255, 0.85);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .circle-image img {
      width: 110%;
      height: 110%;
      object-fit: cover;
      mix-blend-mode: multiply;
      opacity: 0.95;
    }

    .circle-caption {
      margin-top: 1.2rem;
      font-family: var(--font-body);
      letter-spacing: 0.05em;
      font-size: 0.95rem;
      text-transform: uppercase;
      color: rgba(44, 24, 16, 0.78);
    }

    .diagram-right {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: stretch;
    }

    .arrow-strip {
      position: relative;
      padding: 0.9rem 1.25rem;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(46, 139, 87, 0.15), rgba(46, 139, 87, 0.5));
      color: var(--color-secondary);
      font-family: var(--font-body);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      box-shadow: 0 12px 24px -10px rgba(46, 139, 87, 0.45);
    }

    .arrow-strip::after {
      content: "";
      position: absolute;
      right: -16px;
      top: 50%;
      transform: translateY(-50%);
      width: 0;
      height: 0;
      border-top: 15px solid transparent;
      border-bottom: 15px solid transparent;
      border-left: 16px solid rgba(46, 139, 87, 0.5);
    }

    .arrow-strip span {
      text-shadow: 0 0 12px rgba(255, 255, 255, 0.6);
    }

    .arrow-strip:hover {
      transform: translateX(6px);
    }

    @media (max-width: 1024px) {
      .diagram-grid {
        grid-template-columns: 1fr;
        justify-items: center;
      }

      .diagram-right {
        width: min(360px, 100%);
      }

      .arrow-strip::after {
        display: none;
      }
    }

    @media (max-width: 640px) {
      .label-card {
        letter-spacing: 0.05em;
        font-size: 0.85rem;
      }

      .circle-caption {
        letter-spacing: 0.05em;
      }

      .arrow-strip {
        letter-spacing: 0.05em;
        font-size: 0.75rem;
      }
    }

    @keyframes slowSpin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
  </style>
</Layout>
