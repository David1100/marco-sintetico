---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Marco Sintético - Inicio">
  <!-- Hero Section -->
  <div class="min-h-[70vh] flex flex-col items-center justify-center text-center animate-fade-in">
    <div class="mb-8">
      <span class="material-symbols-outlined text-primary text-6xl mb-4">eco</span>
    </div>
    
    <h1 class="font-headline font-extrabold text-5xl text-primary tracking-tight mb-4">
      Marco Sintético
    </h1>
    
    <p class="font-body text-xl text-on-surface-variant max-w-2xl mb-8">
      La apropiación de la productividad social
    </p>
    
    <p class="text-lg text-on-surface-variant max-w-3xl mb-12">
      Ecosistema visual para articular la comprensión y análisis de la productividad social desde una perspectiva relacional
    </p>
    
    <a 
      href="/apropiacion-productividad-social"
      class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-full font-medium hover:bg-primary/90 transition-all hover:scale-105 shadow-lg"
    >
      Comenzar exploración
      <span class="material-symbols-outlined">arrow_forward</span>
    </a>
  </div>
</Layout>
