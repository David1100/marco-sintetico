---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Capital Social: El Ecosistema de la Región - Marco Sintético">
  <!-- Title Section -->
  <header class="w-full max-w-7xl pt-8 pb-12 flex flex-col items-center text-center animate-fade-in">
    <span class="text-primary font-headline font-bold tracking-widest uppercase text-xs mb-4 animate-slide-up" style="animation-delay: 0.1s; opacity: 0;">Estructura de Productividad Social</span>
    <h1 class="text-primary font-headline font-extrabold text-5xl md:text-6xl tracking-tighter leading-none max-w-4xl animate-slide-up" style="animation-delay: 0.2s; opacity: 0;">
      Capital Social: El Ecosistema de la Región
    </h1>
    <div class="mt-8 h-1 w-24 bg-secondary rounded-full animate-scale-in" style="animation-delay: 0.4s;"></div>
  </header>
    <span class="text-primary font-headline font-bold tracking-widest uppercase text-xs mb-4">Estructura de Productividad Social</span>
    <h1 class="text-primary font-headline font-extrabold text-5xl md:text-6xl tracking-tighter leading-none max-w-4xl">
      Capital Social: El Ecosistema de la Región
    </h1>
    <div class="mt-8 h-1 w-24 bg-secondary rounded-full"></div>
  </header>

  <!-- Main Diagram Canvas -->
  <main class="relative w-full max-w-6xl aspect-square md:aspect-video flex items-center justify-center p-8 mb-16">
    <!-- SVG Connections Layer -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewbox="0 0 1000 600">
      <!-- Central Connection Paths -->
      <path class="connection-line animate-flow" style="animation-delay: 0.5s;" d="M 500 300 C 400 300, 300 200, 200 150"></path>
      <path class="connection-line animate-flow" style="animation-delay: 0.6s;" d="M 500 300 C 600 300, 700 200, 800 150"></path>
      <path class="connection-line animate-flow" style="animation-delay: 0.7s;" d="M 500 300 C 500 400, 400 500, 300 550"></path>
      <path class="connection-line animate-flow" style="animation-delay: 0.8s;" d="M 500 300 C 500 400, 600 500, 700 550"></path>
      <!-- Circular Orbit Line -->
      <circle class="animate-flow" cx="500" cy="300" fill="none" r="220" stroke="#dfe3e7" stroke-dasharray="8 8" stroke-width="1" style="animation-delay: 0.4s;"></circle>
      <!-- Central Core Relationships -->
      <path class="central-axis animate-pulse-node" style="animation-delay: 0.3s;" d="M 420 300 L 580 300"></path>
      <path class="central-axis animate-pulse-node" style="animation-delay: 0.3s;" d="M 500 220 L 500 380"></path>
    </svg>

    <!-- Core Relationship Center -->
    <div class="relative z-10 flex flex-col items-center justify-center animate-scale-in" style="animation-delay: 0.3s; opacity: 0;">
      <div class="w-48 h-48 rounded-full bg-surface-container-lowest border-4 border-primary shadow-2xl flex flex-col items-center justify-center text-center p-6 backdrop-blur-md bg-opacity-80 animate-pulse-node">
        <span class="text-primary font-headline font-black text-xl leading-tight">EL HÁBITAT</span>
        <div class="my-2 h-px w-8 bg-outline-variant"></div>
        <span class="text-on-surface-variant font-body font-semibold text-sm">Contexto Inmediato</span>
      </div>
      <!-- Floating Inner Orbit Text -->
      <div class="absolute -top-16 bg-secondary-container/10 border border-secondary/20 px-4 py-1 rounded-full backdrop-blur-sm animate-slide-up" style="animation-delay: 0.6s; opacity: 0;">
        <span class="text-secondary font-headline font-bold text-xs uppercase tracking-wider">La Región</span>
      </div>
    </div>

    <!-- Pillars Circular Arrangement -->
    <!-- Top -->
    <div class="pillar-node absolute top-[10%] left-1/2 -translate-x-1/2 w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">lightbulb</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Creatividad</span>
    </div>
    <!-- Top Right -->
    <div class="pillar-node absolute top-[20%] right-[15%] w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">psychology</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Simbiosis</span>
    </div>
    <!-- Right -->
    <div class="pillar-node absolute top-[50%] -translate-y-1/2 right-[5%] w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">terminal</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Cibernética</span>
    </div>
    <!-- Bottom Right -->
    <div class="pillar-node absolute bottom-[20%] right-[15%] w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">factory</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Productividad</span>
    </div>
    <!-- Bottom Left -->
    <div class="pillar-node absolute bottom-[5%] left-[60%] w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">account_tree</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Gestión</span>
    </div>
    <!-- Left Bottom -->
    <div class="pillar-node absolute bottom-[5%] right-[60%] w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">museum</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Cultura</span>
    </div>
    <!-- Left -->
    <div class="pillar-node absolute bottom-[20%] left-[15%] w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">diversity_3</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Pluralismo</span>
    </div>
    <!-- Left Top -->
    <div class="pillar-node absolute top-[50%] -translate-y-1/2 left-[5%] w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">hub</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Convergencia</span>
    </div>
    <!-- Top Left -->
    <div class="pillar-node absolute top-[20%] left-[15%] w-40 flex flex-col items-center">
      <div class="bg-surface-container-highest p-4 rounded-xl shadow-sm mb-3">
        <span class="material-symbols-outlined text-primary text-3xl">architecture</span>
      </div>
      <span class="font-headline font-bold text-on-surface text-sm">Planificación</span>
    </div>
  </main>

  <!-- Technical Detail Sections -->
  <section class="w-full max-w-7xl grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
    <div class="glass-card p-10 rounded-2xl">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center">
          <span class="material-symbols-outlined text-on-primary text-xl">trending_up</span>
        </div>
        <h3 class="font-headline font-bold text-xl text-primary">Productividad Social</h3>
      </div>
      <p class="text-on-surface-variant font-body leading-relaxed">
        Define el flujo de valor generado por la interacción de los nueve pilares dentro del Hábitat. No es solo rendimiento económico, sino la capacidad del sistema para regenerar sus propios recursos creativos y culturales.
      </p>
    </div>
    <div class="glass-card p-10 rounded-2xl border-l-4 border-secondary">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center">
          <span class="material-symbols-outlined text-on-secondary text-xl">settings_input_component</span>
        </div>
        <h3 class="font-headline font-bold text-xl text-secondary">Transformación y Regulación</h3>
      </div>
      <p class="text-on-surface-variant font-body leading-relaxed">
        Mecanismos de equilibrio que permiten a la Región adaptarse a presiones externas. La regulación asegura que el crecimiento no comprometa la integridad de la Simbiosis y el Pluralismo regional.
      </p>
    </div>
  </section>

  <!-- Technical Notes -->
  <section class="w-full bg-surface-container-highest rounded-2xl p-8 mb-8">
    <h4 class="font-headline font-bold text-on-surface mb-4">Notas Técnicas</h4>
    <p class="text-on-surface-variant text-sm font-body leading-relaxed">
      Este diagrama representa la interconectividad sistémica de la región. Cada nodo es interdependiente; la falla de uno compromete la estabilidad del Capital Social total. Los vectores de flujo indican la transferencia de conocimiento y energía cívica.
    </p>
  </section>

  <!-- Navegación -->
  <div class="flex justify-between">
    <a href="/apropiacion-productividad-social" class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors">
      <span class="material-symbols-outlined">arrow_back</span>
      Anterior
    </a>
  </div>

  <style>
    .pillar-node {
      transition: all 0.3s ease;
    }
    .pillar-node:hover {
      transform: translateY(-4px);
    }
    .pillar-node:hover .bg-surface-container-highest {
      background-color: #f0f4f8;
    }
    .connection-line {
      stroke: #c4c6cd;
      stroke-width: 1.5;
      fill: none;
      opacity: 0.4;
    }
    .central-axis {
      stroke: #205f44;
      stroke-width: 2;
      stroke-dasharray: 4 4;
    }
  </style>
</Layout>
