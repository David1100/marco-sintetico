---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Página 16 - La contradicción">
  <article class="page-wrap">
    <header class="page-header animate-fade-in" style="animation-delay: 0s; opacity: 0;">
      <p class="page-meta">La lucha por la alimentación entre el modo tributario y el modo capitalista:</p>
      <h1 class="page-title">La Contradicción</h1>
      <p class="page-subtitle">De la ciberseguridad artificial sobre la ciberseguridad natural</p>
    </header>

    <section class="rows">
      <article class="row animate-slide-up" style="animation-delay: 0.1s; opacity: 0;">
        <div class="row-label">
          <p class="row-heading">CLIMA</p>
        </div>
        <div class="row-arrow">
          <span>〉</span>
        </div>
        <div class="row-content">
          <p class="row-title">AGRICULTURA CAPSULADA :</p>
          <p class="row-note">- CONTROL ARTIFICIAL DEL MICROCLIMA</p>
        </div>
        <div class="row-illustration">
          <div class="circle-slot">
            <img src="/images/pagina16/agricultura-capsulada.png" alt="Agricultura capsulada" loading="lazy" decoding="async" onerror="this.remove();" />
          </div>
        </div>
      </article>

      <article class="row animate-slide-up" style="animation-delay: 0.2s; opacity: 0;">
        <div class="row-label">
          <p class="row-heading">SUELO</p>
        </div>
        <div class="row-arrow">
          <span>〉</span>
        </div>
        <div class="row-content">
          <p class="row-title">CONSTRUCCIÓN DEL SUELO :</p>
          <p class="row-note">- RIEGO POR GOTEO</p>
        </div>
        <div class="row-illustration">
          <div class="circle-slot">
            <img src="/images/pagina16/construccion-suelo.png" alt="Construcción del suelo" loading="lazy" decoding="async" onerror="this.remove();" />
          </div>
        </div>
      </article>

      <article class="row animate-slide-up" style="animation-delay: 0.3s; opacity: 0;">
        <div class="row-label">
          <p class="row-heading">NUTRIENTES</p>
        </div>
        <div class="row-arrow">
          <span>〉</span>
        </div>
        <div class="row-content">
          <p class="row-title">TECNOLOGÍA GENÉTICA :</p>
          <p class="row-note">- GIMTEC</p>
          <p class="row-foot">Retroalimentación de la Simbiosis Económica</p>
        </div>
        <div class="row-illustration">
          <div class="circle-slot">
            <img src="/images/pagina16/tecnologia-genetica.png" alt="Tecnología genética" loading="lazy" decoding="async" onerror="this.remove();" />
          </div>
        </div>
      </article>
    </section>
  </article>

  <PageNav prev={{ href: "/las-nuevas-fronteras", label: "Las Nuevas Fronteras", sublabel: "Tecnologías" }} next={{ href: "/espacio-natural-exuberancia", label: "Espacio Natural", sublabel: "Zona Tropical" }} />

  <style>
    .page-wrap {
      background: rgba(255, 255, 255, 0.95);
      border-radius: 2.5rem;
      border: 1px solid rgba(44, 24, 16, 0.12);
      box-shadow: 0 20px 50px rgba(44, 24, 16, 0.2);
      padding: clamp(1.5rem, 4vw, 3.5rem);
    }

    .page-meta {
      font-size: 0.85rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 0.8rem;
      color: rgba(44, 24, 16, 0.7);
    }

    .page-title {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      letter-spacing: 0.02em;
      text-align: center;
      margin-bottom: 0.25rem;
      color: var(--color-primary);
    }

    .page-subtitle {
      font-size: 0.95rem;
      letter-spacing: 0.02em;
      text-align: center;
      color: rgba(44, 24, 16, 0.65);
    }

    .rows {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-top: 2.5rem;
    }

    .row {
      display: grid;
      grid-template-columns: minmax(80px, 140px) auto minmax(220px, 1fr) minmax(120px, 160px);
      gap: 1rem;
      align-items: center;
      border-top: 1px dashed rgba(44, 24, 16, 0.2);
      padding-top: 1.25rem;
    }

    .row:first-of-type {
      border-top: none;
      padding-top: 0;
    }

    .row-heading {
      font-family: var(--font-body);
      font-size: 1.1rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .row-arrow span {
      font-size: 2.5rem;
      color: rgba(44, 24, 16, 0.65);
    }

    .row-title {
      font-family: var(--font-body);
      font-size: 1.15rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .row-note {
      font-size: 0.85rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(44, 24, 16, 0.7);
    }

    .row-foot {
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(44, 24, 16, 0.6);
      margin-top: 0.4rem;
    }

    .circle-slot {
      width: 110px;
      height: 110px;
      border-radius: 999px;
      border: 1px dashed rgba(44, 24, 16, 0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: rgba(255, 253, 247, 0.8);
    }

    .circle-slot img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 900px) {
      .row {
        grid-template-columns: 1fr;
        border-top: 1px dashed rgba(44, 24, 16, 0.2);
        padding-top: 1rem;
        text-align: center;
      }

      .row-arrow span {
        display: inline-block;
        transform: rotate(90deg);
      }

      .row-illustration {
        display: flex;
        justify-content: center;
      }
    }
  </style>
</Layout>
