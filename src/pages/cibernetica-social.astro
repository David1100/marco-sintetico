---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";

// ── Geometry constants ──
const cx = 500;
const cy = 500;
const outerR = 350;
const innerR = 262.5;

function polar(r, deg) {
  const rad = (deg * Math.PI) / 180;
  return { x: +(cx + r * Math.cos(rad)).toFixed(1), y: +(cy - r * Math.sin(rad)).toFixed(1) };
}

const fmt = (p) => `${p.x} ${p.y}`;

// ── Nodes (6 positions on inner circle) ──
const nodeAngles = [90, 30, 330, 270, 210, 150];
const nodes = nodeAngles.map((a) => ({ angle: a, ...polar(innerR, a) }));

// ── Arc paths for text ──
const topTextPath = `M ${fmt(polar(375, 160))} A 250 375 0 0 0 ${fmt(polar(375, 20))}`;
const bottomTextPath = `M ${fmt(polar(375, 200))} A 260 375 0 0 1 ${fmt(polar(375, 340))}`;
const leftTextPath = `M ${fmt(polar(375, 190))} A 375 375 0 0 1 ${fmt(polar(375, 170))}`;
const rightTextPath = `M ${fmt(polar(375, 30))} A 375 375 0 0 1 ${fmt(polar(375, 330))}`;

// ── Center-to-node curved connections (clockwise spiral) ──
const centerLines = nodeAngles.map((θ) => {
  const c1 = polar(87, θ - 15);
  const c2 = polar(175, θ - 30);
  const end = polar(innerR, θ);
  return `M ${cx} ${cy} C ${fmt(c1)}, ${fmt(c2)}, ${fmt(end)}`;
});

// ── Arrow on outer circle ──
const arrowStart = polar(outerR, 150);
const arrowEnd = polar(outerR, 30);
const arrowPath = `M ${fmt(arrowStart)} A ${outerR} ${outerR} 0 0 0 ${fmt(arrowEnd)}`;

// ── Clockwise arrow arcs on outer circle near each text label ──
// Each arc places the marker at the text angle, no stroke visible
const arrowArcs = [
  [163, 155],  // LA MANERA (left, ~155°)
  [34, 26],    // LA FORMA (top-right, ~26°)
  [214, 206],  // CRONICOS (bottom-left, ~206°)
  [341, 333],  // DESECHOS (bottom-right, ~333°)
];
const arrowArcPaths = arrowArcs.map(([from, to]) => {
  const s = polar(outerR, from);
  const e = polar(outerR, to);
  return `M ${fmt(s)} A ${outerR} ${outerR} 0 0 0 ${fmt(e)}`;
});
---

<Layout title="Cibernética Social - La Revolución del Ciberneta">
  <section class="relative w-full flex justify-center items-center py-8 animate-fade-in">
    <div class="absolute left-[8%] top-[6%] z-10">
      <h3 class="font-body text-2xl font-extrabold text-primary tracking-tight leading-none">
        CIBERNÉTICA SOCIAL:
      </h3>
      <p class="text-sm text-on-surface-variant font-light italic mt-1">
        Paso Histórico del Alfabeta al Ciberneta
      </p>
    </div>
    <svg
      viewBox="0 0 1000 1000"
      class="w-full max-w-[900px] h-auto"
      style="filter: drop-shadow(0 20px 60px rgba(44,24,16,0.12));"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <marker
          id="arrowhead"
          viewBox="0 0 12 12"
          refX="10"
          refY="6"
          markerWidth="10"
          markerHeight="10"
          orient="auto"
        >
          <path d="M 0 0 L 12 6 L 0 12 z" fill="#2C1810" />
        </marker>
        <marker
          id="circle-arrow"
          viewBox="0 0 10 10"
          refX="8"
          refY="5"
          markerWidth="11"
          markerHeight="11"
          orient="auto"
        >
          <path d="M 0 0 L 10 5 L 0 10 z" fill="#2C1810" />
        </marker>

        <path id="arc-top" d={topTextPath} />
        <path id="arc-bottom" d={bottomTextPath} />
        <path id="arc-left" d={leftTextPath} />
        <path id="arc-right" d={rightTextPath} />
      </defs>

      <!-- Outer circle -->
      <circle
        cx={cx} cy={cy} r={outerR}
        fill="none"
        stroke="#2C1810"
        stroke-width="2.5"
        opacity="0.85"
      />

      <!-- Clockwise arrowheads on outer circle (stroke hidden, only marker visible) -->
      <g fill="none" stroke="none" marker-end="url(#circle-arrow)">
        {arrowArcPaths.map((d) => <path d={d} />)}
      </g>

      <!-- Inner concentric circle -->
      <circle
        cx={cx} cy={cy} r={innerR}
        fill="none"
        stroke="#5D4037"
        stroke-width="1.2"
        opacity="0.5"
      />

      <!-- Center-to-node clockwise curved connections -->
      <g fill="none" stroke="#5D4037" stroke-width="1.5" opacity="0.5">
        {centerLines.map((d) => <path d={d} />)}
      </g>

      <!-- Center point -->
      <circle cx={cx} cy={cy} r="7" fill="#2C1810" opacity="0.9" />

      <!-- Nodes -->
      {nodes.map((n) => (
        <circle cx={n.x} cy={n.y} r="8" fill="#000000" />
      ))}

      <!-- Node labels -->
      <text x="500" y="182" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#2C1810" letter-spacing="3">EL MODO</text>
      <text x="773" y="368" text-anchor="start" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="#2C1810" letter-spacing="2.5">LA FORMA</text>
      <text x="773" y="638" text-anchor="start" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="#2C1810" letter-spacing="2.5">DESECHOS</text>
      <text x="500" y="815" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#2C1810" letter-spacing="3">ENTROPIA</text>
      <text x="222" y="638" text-anchor="end" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="#2C1810" letter-spacing="2.5">CRONICOS</text>
      <text x="222" y="368" text-anchor="end" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="#2C1810" letter-spacing="2.5">LA MANERA</text>

      <!-- Arc text: top -->
      <text font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#2C1810" letter-spacing="3" opacity="0.75">
        <textPath href="#arc-top" startOffset="50%" text-anchor="middle">LA RETROALIMENTACION HUMANA</textPath>
      </text>

      <!-- Arc text: bottom -->
      <text font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#2C1810" letter-spacing="2" opacity="0.75">
        <textPath href="#arc-bottom" startOffset="50%" text-anchor="middle">LA ENERGIA PERDIDA</textPath>
      </text>

      <!-- Arc text: left side -->
      <text font-family="Inter, sans-serif" font-size="8" font-weight="600" fill="#5D4037" letter-spacing="2" opacity="0.55">
        <textPath href="#arc-left" startOffset="50%" text-anchor="middle">LOS POBRES DE YAVE</textPath>
      </text>

      <!-- Arc text: right side -->
      <text font-family="Inter, sans-serif" font-size="8" font-weight="600" fill="#5D4037" letter-spacing="2" opacity="0.55">
        <textPath href="#arc-right" startOffset="50%" text-anchor="middle">LOS DESPERDICIOS DE LA PRODUCCIÓN</textPath>
      </text>
    </svg>
  </section>

  <PageNav
    prev={{
      href: "/coordinacion-transformacion",
      label: "Coordinación",
      sublabel: "Transformación",
    }}
    next={{
      href: "/tecnologia-punta-propia",
      label: "Tecnología",
      sublabel: "Punta",
    }}
  />
</Layout>
