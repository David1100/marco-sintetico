---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Página 20 - Práctica de Pervivencia">
  <article class="sheet">
    <header class="sheet-header animate-fade-in">
      <p class="sheet-meta">Teoría de Sistemas</p>
      <h1 class="sheet-title">Práctica de Pervivencia</h1>
      <p class="sheet-subtitle">Productividad Social</p>
    </header>

    <section class="diagram animate-slide-up" style="animation-delay: 0.1s; opacity: 0;">
      <!-- SVG Connection Lines (Background) -->
      <svg class="connections" viewBox="0 0 1000 600">
        <defs>
          <linearGradient id="lineGrad" x1="0%" x2="100%">
            <stop offset="0%" stop-color="var(--color-primary)" stop-opacity="0.3"></stop>
            <stop offset="50%" stop-color="var(--color-secondary)" stop-opacity="0.5"></stop>
            <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.3"></stop>
          </linearGradient>
        </defs>
        <path class="connection-line" d="M500,300 L500,80" fill="none" stroke="url(#lineGrad)" stroke-width="2"></path>
        <path class="connection-line" d="M500,300 L750,200" fill="none" stroke="url(#lineGrad)" stroke-width="2"></path>
        <path class="connection-line" d="M500,300 L650,500" fill="none" stroke="url(#lineGrad)" stroke-width="2"></path>
        <path class="connection-line" d="M500,300 L350,500" fill="none" stroke="url(#lineGrad)" stroke-width="2"></path>
        <path class="connection-line" d="M500,300 L250,200" fill="none" stroke="url(#lineGrad)" stroke-width="2"></path>
      </svg>

      <!-- Central Circle with Float Animation -->
      <div class="center-node animate-float">
        <div class="circle-frame">
          <img 
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuA-zkGLKjuSZbKya1DJA3tQw86PrGQr4U9Zs7AYp2BMSwEF06YSmSxkzEcgBxQ0jHTRouJV5VUpaRDFi5TjxAxF4W0Ov2LtFnOdNaR_Xq6K1B3ubjDQmmlue3rFRIjBts7ummfjPZ7EkFiQKU4_4gq1ydSzQN2_fiuV4-n29-vwREIsEZn0J6Dw8iCg-32pVkIgaGvhwofo8TTEzzphaFcccUYBS4Rmxk69R2c1lK11SLelh83E649XA7FP4BjjHv3ooiuXXDy-1xPn" 
            alt="Concreción Vital"
            class="w-full h-full object-cover rounded-full"
          />
        </div>
        <p class="circle-label">Concreción Vital</p>
      </div>

      <!-- Satellite Nodes -->
      <div class="satellite-nodes">
        <!-- Node 1: Jugo -->
        <div class="satellite-node node-1 animate-slide-up" style="animation-delay: 0.2s; opacity: 0;">
          <div class="node-card glass-card">
            <span class="material-symbols-outlined text-secondary">opacity</span>
            <h3 class="node-title">Jugo</h3>
            <p class="node-desc">Esencia líquida de la productividad social</p>
          </div>
        </div>

        <!-- Node 2: Pulpa -->
        <div class="satellite-node node-2 animate-slide-up" style="animation-delay: 0.3s; opacity: 0;">
          <div class="node-card glass-card">
            <span class="material-symbols-outlined text-secondary">grain</span>
            <h3 class="node-title">Pulpa</h3>
            <p class="node-desc">Cuerpo denso de la síntesis cibernética</p>
          </div>
        </div>

        <!-- Node 3: Cáscara -->
        <div class="satellite-node node-3 animate-slide-up" style="animation-delay: 0.4s; opacity: 0;">
          <div class="node-card glass-card">
            <span class="material-symbols-outlined text-primary">shield</span>
            <h3 class="node-title">Cáscara</h3>
            <p class="node-desc">Protección y estructura del sistema</p>
          </div>
        </div>

        <!-- Node 4: Fibras -->
        <div class="satellite-node node-4 animate-slide-up" style="animation-delay: 0.5s; opacity: 0;">
          <div class="node-card glass-card">
            <span class="material-symbols-outlined text-primary">rebase_edit</span>
            <h3 class="node-title">Fibras</h3>
            <p class="node-desc">Conexiones relacionales técnicas</p>
          </div>
        </div>

        <!-- Node 5: Follaje -->
        <div class="satellite-node node-5 animate-slide-up" style="animation-delay: 0.6s; opacity: 0;">
          <div class="node-card glass-card">
            <span class="material-symbols-outlined text-primary">eco</span>
            <h3 class="node-title">Follaje</h3>
            <p class="node-desc">Captación de recursos externos</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="content-grid animate-slide-up" style="animation-delay: 0.7s; opacity: 0;">
      <div class="content-main">
        <h2 class="content-title">
          Manera relacional <br/>
          <span class="text-variant">(producción técnica)</span>
        </h2>
        <h2 class="content-title text-secondary">
          vs Síntesis de la Concreción
        </h2>
        <h2 class="content-title">
          <span class="text-variant">(cibernética)</span>
        </h2>
      </div>

      <div class="quote-card glass-card">
        <p class="quote-text">"Múltiples relaciones en la integración de los usos y la universalización de las cosas"</p>
        <p class="quote-source">FRAGMENTO DE PERVIVENCIA</p>
      </div>

      <div class="stats-grid">
        <div class="stat-card glass-card">
          <span class="stat-number">01</span>
          <h4 class="stat-title">Integración</h4>
          <p class="stat-desc">Capacidad de ensamblar fragmentos en un todo funcional</p>
        </div>
        <div class="stat-card glass-card">
          <span class="stat-number stat-number--secondary">02</span>
          <h4 class="stat-title">Universalización</h4>
          <p class="stat-desc">Extensión del uso técnico hacia la totalidad del ecosistema</p>
        </div>
      </div>
    </section>
  </article>

  <PageNav
    prev={{ href: "/coordinacion-transformacion", label: "Coordinación", sublabel: "Transformación" }}
    next={{ href: "/espacio-natural-exuberancia", label: "Espacio Natural", sublabel: "Exuberancia" }}
  />

  <style>
    .sheet {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(250, 242, 226, 0.92));
      border-radius: 2.5rem;
      padding: clamp(1.5rem, 5vw, 3rem);
      border: 1px solid rgba(44, 24, 16, 0.12);
      box-shadow: 0 20px 50px rgba(44, 24, 16, 0.15);
    }

    .sheet-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .sheet-meta {
      font-family: var(--font-body);
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-secondary);
      margin-bottom: 0.5rem;
    }

    .sheet-title {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: clamp(2rem, 5vw, 3.5rem);
      letter-spacing: 0.02em;
      color: var(--color-primary);
      margin-bottom: 0.5rem;
    }

    .sheet-subtitle {
      font-family: var(--font-body);
      font-size: 1rem;
      letter-spacing: 0.05em;
      color: rgba(44, 24, 16, 0.6);
    }

    .diagram {
        padding: 50px;
      position: relative;
      min-height: 700px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 2rem 0;
      overflow: hidden;
    }

    .connections {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    .center-node {
      position: relative;
      z-index: 10;
    }

    .circle-frame {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      overflow: hidden;
      border: 6px solid var(--color-surface-container-lowest);
      box-shadow: 0 10px 40px rgba(44, 24, 16, 0.2);
    }

    .circle-label {
      position: absolute;
      bottom: -1.5rem;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      color: var(--color-primary);
      white-space: nowrap;
    }

    .satellite-nodes {
      position: absolute;
      inset: 0;
      z-index: 5;
    }

    .satellite-node {
      position: absolute;
    }

    .node-1 { top: 15%; left: 43%; transform: translateX(-50%); }
    .node-2 { top: 20%; right: 15%; }
    .node-3 { bottom: 10%; right: 28%; }
    .node-4 { bottom: 10%; left: 28%; }
    .node-5 { top: 20%; left: 15%; }

    .node-card {
      width: 160px;
      padding: 1rem;
      border-radius: 1rem;
      text-align: center;
    }

    .node-card .material-symbols-outlined {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .node-title {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: 1rem;
      color: var(--color-primary);
      margin-bottom: 0.25rem;
    }

    .node-desc {
      font-family: var(--font-body);
      font-size: 0.7rem;
      color: rgba(44, 24, 16, 0.7);
      line-height: 1.3;
    }

    .connection-line {
      stroke-dasharray: 1000;
      stroke-dashoffset: 1000;
      animation: drawLine 3s ease-out forwards;
    }

    @keyframes drawLine {
      to { stroke-dashoffset: 0; }
    }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-top: 2rem;
    }

    .content-title {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: 2rem;
      line-height: 1.3;
      color: var(--color-primary);
      margin-bottom: 1rem;
    }

    .text-variant {
      font-weight: 400;
      font-style: italic;
      color: rgba(44, 24, 16, 0.6);
    }

    .content-title.text-secondary {
      color: var(--color-secondary);
    }

    .quote-card {
      padding: 1.5rem;
      border-left: 4px solid var(--color-primary);
      border-radius: 0 1rem 1rem 0;
    }

    .quote-text {
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 1.1rem;
      color: var(--color-tertiary);
      font-style: italic;
      line-height: 1.4;
    }

    .quote-source {
      font-family: var(--font-body);
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      color: var(--color-outline);
      margin-top: 1rem;
    }

    .stats-grid {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-card {
      padding: 1.25rem;
      border-radius: 1rem;
    }

    .stat-number {
      font-family: var(--font-body);
      font-weight: 900;
      font-size: 2.5rem;
      color: rgba(139, 69, 19, 0.15);
      display: block;
      margin-bottom: 0.5rem;
    }

    .stat-number--secondary {
      color: rgba(46, 139, 87, 0.15);
    }

    .stat-title {
      font-family: var(--font-body);
      font-weight: 800;
      font-size: 1rem;
      color: var(--color-primary);
      margin-bottom: 0.25rem;
    }

    .stat-desc {
      font-family: var(--font-body);
      font-size: 0.75rem;
      color: rgba(44, 24, 16, 0.7);
    }

    @media (max-width: 768px) {
      .content-grid {
        grid-template-columns: 1fr;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .satellite-node {
        position: relative;
        top: auto !important;
        left: auto !important;
        right: auto !important;
        bottom: auto !important;
        transform: none !important;
        margin: 0.5rem 0;
      }

      .node-card {
        width: 100%;
        flex-direction: row;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .circle-frame {
        width: 120px;
        height: 120px;
      }
    }
  </style>
</Layout>