---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Tecnología Punta Propia - Ecosistema">
  <header class="max-w-5xl mx-auto mb-12 md:mb-16 text-center animate-fade-in">
    <h1 class="font-body text-4xl md:text-5xl lg:text-6xl font-extrabold text-primary tracking-tight mb-4 animate-slide-up">
      PRODUCTIVIDAD: 
    </h1>
    <p class="font-body text-lg text-tertiary-container max-w-2xl mx-auto leading-relaxed animate-slide-up" style="animation-delay: 0.1s; opacity: 0;">
      Tecnología punta propia.
    </p>
  </header>

  <div class="relative flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-20 py-16 px-8">
    
<!-- SVG Lines - positioned absolutely behind circles -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none z-0" viewBox="0 0 1000 400" preserveAspectRatio="xMidYMid meet">
      <defs>
        <marker id="arrow-purple" markerWidth="12" markerHeight="10" refX="11" refY="5" orient="auto">
          <polygon points="0 0, 14 5, 0 10" fill="#6750A4"/>
        </marker>
        <marker id="arrow-green" markerWidth="12" markerHeight="10" refX="11" refY="5" orient="auto">
          <polygon points="0 0, 14 5, 0 10" fill="#9CBA7F"/>
        </marker>
      </defs>
      
      <!-- Line 1 to 2 with Arrow -->
      <line x1="220" y1="200" x2="340" y2="200" stroke="#79747E" stroke-width="4" opacity="0.9" marker-end="url(#arrow-purple)"/>
      
      <!-- Line 3 to 2 with Arrow -->
      <line x1="700" y1="200" x2="560" y2="200" stroke="#6750A4" stroke-width="4" opacity="0.9" marker-end="url(#arrow-purple)"/>
      
      <!-- Line 1 to 3 (above circles) with arrow -->
      <path d="M 160 50 Q 500 -50 820 50" fill="none" stroke="#9CBA7F" stroke-width="4" opacity="0.9" marker-end="url(#arrow-green)"/>
      
      <!-- Line 3 to 1 (below circles) with arrow -->
      <path d="M 820 350 Q 500 450 160 350" fill="none" stroke="#9CBA7F" stroke-width="4" opacity="0.9" marker-end="url(#arrow-green)"/>
    </svg>

    <!-- Circle 1: SABIDURIA POPULAR / TECNOLOGIA PROPIA -->
    <div class="relative flex flex-col items-center z-20 animate-slide-up -left-16" style="animation-delay: 0.2s; opacity: 0;">
      <span class="font-body text-xs font-bold uppercase tracking-widest text-secondary backdrop-blur-lg mb-3 px-4 py-1 bg-secondary-container/30 rounded-full shadow-sm">
        SABIDURÍA POPULAR
      </span>
      <div class="relative w-44 h-44 md:w-52 md:h-52 lg:w-56 lg:h-56">
        <div class="absolute inset-0 rounded-full border-4 border-secondary-container shadow-xl"></div>
        <img 
          class="w-full h-full object-cover rounded-full" 
          alt="Tecnología Propia" 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDoByAIQwSMJMRouGUEWIk23Ze1tq5fKkKgAfli5dll9f_etraEv6Oy8sqcSDjDp66suE1qvpIs3kwDGe_5Y1bEAq_LeKPm_3Izx0CZk7oPnWp17U37EofXhu2Ms9-5eqhRQ0YKsSFHAkrvmOElsB32R1CQ0OChr-aSTeGNT4lhisXjgfRvukLGP_IyPhm_GKGdmn94U9pnmZ3tv7Wkz3RG2JnVB3_KBDQuRrze1umXu98Yu_vC1pV1rYHGHLmOR23-uOsoXzh_4Lny"
        />
      </div>
      <span class="font-body text-sm font-bold uppercase tracking-wider text-primary mt-4 px-4 py-2 bg-primary-container/30 backdrop-blur-lg rounded-full shadow-sm">
        TECNOLOGÍA PROPIA
      </span>
    </div>

    <!-- Circle 2: SOFTWARE DE LA MANERA / TECNOLOGIA PUNTA PROPIA -->
    <div class="relative flex flex-col items-center z-20 animate-slide-up" style="animation-delay: 0.4s; opacity: 0;">
      <span class="font-body text-xs font-bold uppercase tracking-widest text-primary mb-3 px-4 py-1 bg-primary-container/30 backdrop-blur-lg rounded-full shadow-sm">
        SOFTWARE DE LA MANERA
      </span>
      <div class="relative w-52 h-52 md:w-60 md:h-60 lg:w-64 lg:h-64">
        <div class="absolute inset-0 bg-primary/10 rounded-full blur-2xl animate-pulse"></div>
        <div class="absolute inset-0 rounded-full border-8 border-primary-container shadow-2xl"></div>
        <img 
          class="w-full h-full object-cover rounded-full" 
          alt="Tecnología Punta Propia" 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBH9ZV4BlZgOLcsZh7lCFwVhKrHPDs_uMn5v4Wdc2-z8BztCdR3e_W8lJeWb0DjWuFNowAN-gp-cxNBuz6--LNAggGbjxC6xqg3Amv2YB-QR83K6xQ3HLSRHlbMa9WDWGX16noTbzEv9zEaAYc4spFvQgzc7acr8sN2BqaCsmgeoxowySs6TtPzF-748dLwCrCW_-e7JJV8Kp49Iftht8iMQ9ZPGIRFp_6W7uTYBdlWQetHCwOTrYmdJjZxd99pa7MCLJ-yKtG53iiR"
        />
      </div>
      <span class="font-body text-sm font-bold uppercase tracking-wider text-primary mt-4 px-4 py-2 bg-primary-container/30 backdrop-blur-lg rounded-full shadow-sm">
        TECNOLOGÍA PUNTA PROPIA
      </span>
    </div>

    <!-- Circle 3: SOFTWARE DEL MODO / TRANSFERENCIA TECNOLOGIA DE PUNTA -->
    <div class="relative flex flex-col items-center z-20 animate-slide-up" style="animation-delay: 0.6s; opacity: 0;">
      <span class="font-body text-xs font-bold uppercase backdrop-blur-lg tracking-widest text-tertiary mb-3 px-4 py-1 bg-tertiary-container/30 rounded-full shadow-sm">
        SOFTWARE DEL MODO
      </span>
      <div class="relative w-44 h-44 md:w-52 md:h-52 lg:w-56 lg:h-56">
        <div class="absolute inset-0 rounded-full border-4 border-tertiary-container shadow-xl"></div>
        <img 
          class="w-full h-full object-cover rounded-full" 
          alt="Transferencia Tecnología de Punta" 
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDuvYFFwtM3KqGFT9kIJ0lnqwijkR0fomDzf9IzMy3F2nyyPruGVZZZzYPUZI_gw6chi02doFLPOF_HiJTFnvcOWPi1aMLVo0Q9fsVD1c8B7JUEeQ_0gmh1UEDknaz0srZ_3tBm5zIh1Tg03Of2WSiiCH4m21IRPGQpSVZLtyDI1yOSfITqg5u66f-wGHhG8015s2LRw_rsIOvStGWYu1WKA_p9ZYaINtxOjgHscXXHL3LS9sXcP8KWLrYq05MckUdBgvuaMNFzfXR5"
        />
      </div>
      <span class="font-body text-sm font-bold backdrop-blur-lg uppercase tracking-wider text-tertiary mt-4 px-4 py-2 bg-tertiary-container/30 rounded-full shadow-sm">
        TRANSFERENCIA TECNOLOGÍA DE PUNTA
      </span>
    </div>

  </div>

  <PageNav
    prev={{ href: "/aptitud-trabajo", label: "Aptitud", sublabel: "Trabajo" }}
    next={{ href: "/reciclaje-cibernetico", label: "Reciclaje", sublabel: "Cibernético" }}
  />
</Layout>