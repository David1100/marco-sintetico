---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Civic Equilibrium - Arquitectura Sistémica">
  <main class="relative w-full max-w-7xl mx-auto px-4 py-12 md:py-20 flex flex-col items-center justify-center min-h-screen">
    <!-- Header -->
    <header class="w-full text-center mb-36 relative z-10 animate-fade-in">
      <h1 class="font-body text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-primary mb-4 animate-slide-up" style="animation-delay: 0s; opacity: 0;">
        Civic Equilibrium
      </h1>
      <p class="font-body text-tertiary uppercase tracking-widest text-sm font-semibold opacity-80 animate-slide-up" style="animation-delay: 0.1s; opacity: 0;">
        Systemic Architecture: Reproducción Humana y Creativa
      </p>
    </header>

    <!-- Main Diagram -->
    <section class="relative w-full aspect-[4/3] md:aspect-[16/9] flex items-center justify-center">
      <!-- SVG Arrows -->
      <svg class="absolute inset-0 w-full h-full pointer-events-none" fill="none" viewbox="0 0 1000 600" xmlns="http://www.w3.org/2000/svg">
        <path class="stroke-primary-container" d="M500 120 L500 240" marker-end="url(#arrowhead-primary)" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
        <path class="stroke-tertiary" d="M280 300 Q350 300 420 300" marker-end="url(#arrowhead-tertiary)" stroke-dasharray="8 4" stroke-width="2"></path>
        <path class="stroke-secondary" d="M720 450 Q600 450 540 380" marker-end="url(#arrowhead-secondary)" stroke-width="2"></path>
        <defs>
          <marker id="arrowhead-primary" markerHeight="7" markerWidth="10" orient="auto" refX="9" refY="3.5">
            <polygon fill="#D2691E" points="0 0, 10 3.5, 0 7"></polygon>
          </marker>
          <marker id="arrowhead-tertiary" markerHeight="7" markerWidth="10" orient="auto" refX="9" refY="3.5">
            <polygon fill="#6B4226" points="0 0, 10 3.5, 0 7"></polygon>
          </marker>
          <marker id="arrowhead-secondary" markerHeight="7" markerWidth="10" orient="auto" refX="9" refY="3.5">
            <polygon fill="#2E8B57" points="0 0, 10 3.5, 0 7"></polygon>
          </marker>
        </defs>
      </svg>

      <!-- Center Node: VALOR AGREGADO -->
      <div class="relative z-20 group animate-slide-up" style="animation-delay: 0.2s; opacity: 0;">
        <div class="w-48 h-48 md:w-64 md:h-64 lg:w-80 lg:h-80 rounded-full bg-surface-container-lowest shadow-2xl p-2 transition-transform duration-500 group-hover:scale-105">
          <div class="w-full h-full rounded-full overflow-hidden relative border-4 border-primary">
            <img class="w-full h-full object-cover grayscale-[20%]" alt="Fábrica" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC0RgSBKhJjm2Wvf82NQknOuAnsqQQucsYxRDk-XQFpedxVXgYlkxvqTIuO3fI_ImjUSK93jXoAXMiQh62KEMHFZAgcq3TWz2piQ_AXlNFLomMBBlrvwEowiq6xZfqdZBCQrMFXHTG9B7SvRxjZUwS-CK_P3TVzQge4K9EAIZbj8miQc0dbxgBkDOisIXkF_6-vGmI4-d-BpotnYV6jiQ0qnaQWMKf11c6HnfltRGgr_r6Vju9V88ruNgcqInGWypl9YIVJWbwkXqn6"/>
            <div class="absolute inset-0 bg-primary/20 backdrop-overlay"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="bg-surface-container-lowest/90 backdrop-blur-md px-4 md:px-6 py-2 md:py-3 rounded-full shadow-lg border border-primary/10">
                <span class="font-body font-bold text-primary tracking-tight text-lg md:text-xl">VALOR AGREGADO</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Top Node: Nodo Maternal -->
      <div class="absolute -top-20 left-1/2 -translate-x-1/2 -translate-y-2 md:translate-y-0 group animate-slide-up" style="animation-delay: 0.3s; opacity: 0;">
        <div class="flex flex-col items-center">
          <div class="mt-2 mb-3 md:mt-3 md:mb-4 bg-primary text-on-primary px-4 md:px-5 py-1.5 md:py-2 rounded-full text-sm md:text-base font-bold shadow-lg">
            Nodo Maternal
          </div>
          <div class="w-28 h-28 md:w-36 md:h-36 lg:w-40 lg:h-40 rounded-full bg-surface-container-lowest shadow-xl p-1.5 border border-primary-container/20 overflow-hidden">
            <img class="w-full h-full object-cover rounded-full" alt="Madre y bebé" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCepT6md5SW8vsTvpwEMFt7-yfR-1fK4HGXKA63liTXl8ytSOeFwNPylsSMt2nar-4SpjPKXS9tIqvdcj9_ehMki5Dp9F4sd_grWoD0zAnWQQdQA4rYUBIKR_IKj3Yv9DRikqcxRSoIZ7BAVU1H8xP5ytQvHCmQvQr7n7N0PchGKbzMCBOQhhJLp1NYsNWkRNhqv9DZd0DYKwaDuWUf_aObS5xnCykpwp1NQTG2FKWZefgpuGvDbvMlfSJBS3dcKw2NaUFqkirLbe9y"/>
          </div>
        </div>
      </div>

      <!-- Left Node: Confianza y Seguridad -->
      <div class="absolute left-0 top-1/2 -translate-y-1/2 max-w-[160px] md:max-w-[220px] lg:max-w-[280px] animate-slide-up" style="animation-delay: 0.4s; opacity: 0;">
        <div class="glass-card p-4 md:p-6 rounded-[2rem] shadow-xl border border-outline-variant/20 flex flex-col gap-4">
          <div class="grid grid-cols-2 gap-2">
            <img class="w-full aspect-square object-cover rounded-xl shadow-sm" alt="Cerámica" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDE6XSlrBlf7MhUscgabkqIPIAq6Y2dAFeHzPDpx46NM5GWK7jM-m7QB1i06knbDj2xCJsR-QJnGAsUoBlILPRoTZ1sSKD3R0yCXH-FrT5my_WAKzlA4oaLf-yAfAKn-DPK698KEK3C_7tw-_NIW1RX4q0MmbWlmvrg-c94TgW2i-VIOM_Wzg_fV1x65CaIpdQQY9-3uzDO1TpW6nfaNC6-CXquqlitXrYWH5O2t7Qu4-4XWVJVxjoqkxTUOIgVahruM3z4FpJJg-dS"/>
            <img class="w-full aspect-square object-cover rounded-xl shadow-sm" alt="Cuidado personal" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBOraw-UBVmcNYCYAgqM105p1rKgiExan8s6SPmSMWpd2Dphy-OwPMy-SwqiGxNV-rgfpuYueWCbbEbjo77xPWTnGSsC0vocE6isHikvSS42Ia4ut0mZvhy_ivqH0X6d1Wxz_sVczBKI1K15O0L6EaVlUuBQzKRiAfGhUtwz56KRDXU3FqFbDEwubhBCsuOgeOaP2-iNxwfSe8zeXOUHiqS1YNCkpySRL3IK8QNwvXs_EGlTK4FITBwQ5DFHun4Cx2dgFr1spvfxVPF"/>
          </div>
          <p class="font-body text-tertiary text-xs md:text-sm font-semibold leading-snug">
            Confianza y Seguridad en la Reproducción Humana y Creativa
          </p>
        </div>
      </div>

      <!-- Right Node: Distribución de la Fiesta -->
      <div class="absolute right-4 bottom-0 md:right-12 md:bottom-12 group animate-slide-up" style="animation-delay: 0.5s; opacity: 0;">
        <div class="relative">
          <div class="w-40 h-40 md:w-52 md:h-52 lg:w-64 lg:h-64 bg-surface-container-highest rounded-full flex items-center justify-center p-3 md:p-4 border border-secondary/20 shadow-lg">
            <div class="relative w-full h-full flex flex-wrap content-center justify-center gap-1">
              <img class="w-12 h-12 md:w-16 md:h-16 lg:w-20 lg:h-20 object-cover rounded-full border-2 border-surface-container-lowest" alt="Profesionales" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAwtN1zGj4YR2cU0XpcrmLoVRovt0xNnQ8uITPKB-jr0Kz08rDVhWEdlUtw1h-8gbYztSP1w3IUnnoGkXnCIouIJ5wjNDPaSj6ZxGl1KVQeRDKzXpCDe5xP0zClwaxBLF2e6lfboXMgUnJ8k1SyDsJLrt_nqOrkSlqaI6VhSP7IgUe11cT0Fc_6DZo994N7MGcfWAkoUb3NYF45Z9yzuQRZ3k4YBqxtEIgWpf_knXvQbcTq1Mfu4X7DdW0XPJCrmlyOov38CTv2q8_n"/>
              <img class="w-12 h-12 md:w-16 md:h-16 lg:w-20 lg:h-20 object-cover rounded-full border-2 border-surface-container-lowest -mt-2 md:-mt-4" alt="Celebración" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCcfln5vjIY1zRotJXPcXynjytmn-nXMXlK-kFEAWra0hrbixszTdau7qldLy_WaycOuH6kOjA2jfqW0QY7yc2D93saswh1fSUXWGV_YL31h4Jx3bsTuLx1G3bZSRQtqyU0t3TorOhFCDanKmOn4oMHspZ-U8Jwr2-CY6r3iG33m8EoNJduAYtbuHnNsxY_YP9Y2vq3dYgBPlyyjTdvMneODifmp3QIoWc1ravUNDnPcn6kt57UQiN6V-s32Cxl28-8n-BdW4dgY2AU"/>
              <img class="w-12 h-12 md:w-16 md:h-16 lg:w-20 lg:h-20 object-cover rounded-full border-2 border-surface-container-lowest" alt="Proyecto artístico" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBZt8hAQb2DHUFuVrE1KUTStc7FE9LOWCHBlHxj6p9AMq5a1jGHYgrpXjEcz2Ol8S_Zs_5KP6_3BnHisy-R5ww777OlmeYab3QkYtKRkqwmiupFO7bAPEZzN1H3Wi6Kt9enCnuOitjVrCWPzBkyNUomoKl-qXKdq36LaYPsnaiM5Rlc76Q2xIuNNEYyatnAROxtz6Kiir1gTxdLQZ6bGmMalo-8o7qOhD5uzouCih0qIjPuEn2SV6FhwYtMLBiGz0wL00vg0R3ylvdm"/>
            </div>
          </div>
          <div class="absolute -bottom-5 md:-bottom-6 right-0 bg-secondary-container text-on-secondary-container px-4 md:px-6 py-2 md:py-3 rounded-xl shadow-xl max-w-[180px] md:max-w-[220px]">
            <p class="font-body font-bold text-xs leading-tight">
              La genialidad de la confianza sensorial del Nodo Maternal
            </p>
            <div class="mt-2 text-[10px] uppercase font-bold opacity-70 tracking-widest">
              Distribution of the Party
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mt-16 md:mt-20 w-full grid grid-cols-1 md:grid-cols-3 gap-8 border-t border-surface-variant/50 pt-10 md:pt-12">
      <div class="space-y-2 animate-slide-up" style="animation-delay: 0.6s; opacity: 0;">
        <div class="flex items-center gap-2 text-primary">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">eco</span>
          <span class="font-body font-bold text-sm uppercase tracking-tighter">Naturaleza</span>
        </div>
        <p class="text-xs text-on-surface-variant leading-relaxed">
          The biological foundation of the system, represented by the Maternal Node and its inherent capacity for regeneration and care.
        </p>
      </div>
      <div class="space-y-2 animate-slide-up" style="animation-delay: 0.7s; opacity: 0;">
        <div class="flex items-center gap-2 text-secondary">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
          <span class="font-body font-bold text-sm uppercase tracking-tighter">Riqueza</span>
        </div>
        <p class="text-xs text-on-surface-variant leading-relaxed">
          The resulting Added Value (Valor Agregado) transformed through the sensory genius of trust and collective human creativity.
        </p>
      </div>
      <div class="space-y-2 animate-slide-up" style="animation-delay: 0.8s; opacity: 0;">
        <div class="flex items-center gap-2 text-tertiary">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">groups</span>
          <span class="font-body font-bold text-sm uppercase tracking-tighter">Sociedad</span>
        </div>
        <p class="text-xs text-on-surface-variant leading-relaxed">
          The distribution layer where human capital and domestic stability create the necessary environment for social reproduction.
        </p>
      </div>
    </footer>

    <!-- System Status -->
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50">
      <div class="glass-card px-6 py-2 rounded-full border border-outline-variant/10 shadow-sm flex items-center gap-4">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
          <span class="text-[10px] font-bold text-tertiary uppercase tracking-widest">System Status: Active Equilibrium</span>
        </div>
      </div>
    </div>
  </main>

  <PageNav
    prev={{ href: "/coexistencia-pacifica", label: "Simbiosis", sublabel: "Económica" }}
    next={{ href: "/sobredeterminacion", label: "Sobredeterminación", sublabel: "Cultura" }}
  />

  <style>
    .bezier-flow {
      stroke-dasharray: 4;
    }
    .backdrop-overlay {
      backdrop-filter: blur(4px);
    }
  </style>
</Layout>