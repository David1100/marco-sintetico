---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Sobredeterminación de la Cultura - Marco Sintético">
  <!-- Title Section -->
  <header class="w-full max-w-7xl pt-8 pb-8 flex flex-col items-center text-center animate-fade-in">
    <h1 class="font-body font-extrabold text-4xl md:text-5xl text-primary tracking-tight mb-4">
      Sobredeterminación de la Cultura
    </h1>
    <p class="font-body text-xl text-on-surface-variant max-w-2xl">
      Sistema de Análisis Sistémico
    </p>
  </header>

  <!-- Main Diagram Section -->
  <main class="relative w-full max-w-4xl mx-auto aspect-square md:aspect-[4/3] flex items-center justify-center p-4 md:p-8 mb-16">
    <!-- SVG Connections -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-35" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="48" fill="none" stroke="#2c694e" stroke-width="1"></circle>
      <line x1="50" y1="5" x2="93" y2="50" stroke="#1c5039" stroke-width="0.7" stroke-dasharray="4 2"></line>
      <line x1="93" y1="50" x2="50" y2="95" stroke="#1c5039" stroke-width="0.7" stroke-dasharray="4 2"></line>
      <line x1="50" y1="95" x2="7" y2="50" stroke="#1c5039" stroke-width="0.7" stroke-dasharray="4 2"></line>
      <line x1="7" y1="50" x2="50" y2="5" stroke="#1c5039" stroke-width="0.7" stroke-dasharray="4 2"></line>
      <line x1="18" y1="20" x2="82" y2="20" stroke="#2c694e" stroke-width="0.7" stroke-dasharray="3 1.5"></line>
      <line x1="82" y1="20" x2="82" y2="80" stroke="#2c694e" stroke-width="0.7" stroke-dasharray="3 1.5"></line>
      <line x1="82" y1="80" x2="18" y2="80" stroke="#2c694e" stroke-width="0.7" stroke-dasharray="3 1.5"></line>
      <line x1="18" y1="80" x2="18" y2="20" stroke="#2c694e" stroke-width="0.7" stroke-dasharray="3 1.5"></line>
      <line x1="18" y1="20" x2="50" y2="50" stroke="#1c5039" stroke-width="0.7" stroke-dasharray="2 1"></line>
      {[
        [50, 5],
        [82, 20],
        [93, 50],
        [82, 80],
        [50, 95],
        [18, 80],
        [7, 50],
        [18, 20],
      ].map(([x, y], idx) => (
        <line
          x1={x}
          y1={y}
          x2={50}
          y2={50}
          stroke="#0e2a1d"
          stroke-width="0.5"
          stroke-dasharray="1.5 1.5"
          key={`radial-${idx}`}
        />
      ))}
    </svg>

    <!-- Enfoque Central (El Núcleo) -->
<div class="relative z-20 w-44 h-44 md:w-78 md:h-78 rounded-full p-1 bg-white shadow-xl flex items-center justify-center overflow-hidden border-4 border-surface-container animate-scale-in" style="animation-delay: 0.3s; opacity: 0;">
      <img alt="Cultura Central" class="absolute inset-0 w-full h-full object-cover" src="/images/sobredeterminacion/cultura.png"/>
      <div class="absolute inset-0 bg-primary/20 mix-blend-overlay"></div>
      <div class="relative z-10 flex flex-col items-center justify-center text-white drop-shadow-lg translate-y-3 md:translate-y-20">
        <span class="font-body font-extrabold text-xl md:text-3xl tracking-widest uppercase">CULTURA</span>
      </div>
    </div>

    <!-- Octagonal Nodes Placement -->
    <!-- Top (0 deg) -->
    <div class="octagon-node text-center animate-slide-up" style="top: 0%; left: 47%; transform: translate(-50%, 0); animation-delay: 0.4s; opacity: 0;">
      <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary shadow-sm mb-2 md:mb-3 hover-lift cursor-pointer">
        <span class="material-symbols-outlined text-2xl md:text-3xl">psychology</span>
      </div>
      <div class="space-y-0.5">
        <p class="font-body font-bold text-xs md:text-sm uppercase text-on-surface">Ideología</p>
        <p class="font-body text-[8px] md:text-[10px] text-on-surface-variant font-medium">(Divinidad)</p>
      </div>
    </div>

    <!-- Top Right (45 deg) -->
    <div class="octagon-node text-center animate-slide-up" style="top: 15%; left: 70%; transform: translate(-50%, 0); animation-delay: 0.5s; opacity: 0;">
      <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary shadow-sm mb-2 md:mb-3 hover-lift cursor-pointer">
        <span class="material-symbols-outlined text-2xl md:text-3xl">hub</span>
      </div>
      <div class="space-y-0.5">
        <p class="font-body font-bold text-xs md:text-sm uppercase text-on-surface">Relaciones</p>
        <p class="font-body text-[8px] md:text-[10px] text-on-surface-variant font-medium">(Red Social)</p>
      </div>
    </div>

    <!-- Right (90 deg) -->
    <div class="octagon-node text-center animate-slide-up" style="top: 45%; left: 79%; transform: translate(-50%, -50%); animation-delay: 0.6s; opacity: 0;">
      <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary shadow-sm mb-2 md:mb-3 hover-lift cursor-pointer">
        <span class="material-symbols-outlined text-2xl md:text-3xl">history_edu</span>
      </div>
      <div class="space-y-0.5">
        <p class="font-body font-bold text-xs md:text-sm uppercase text-on-surface">Historia</p>
        <p class="font-body text-[8px] md:text-[10px] text-on-surface-variant font-medium">(Trascendencia)</p>
      </div>
    </div>

    <!-- Bottom Right (135 deg) -->
    <div class="octagon-node text-center animate-slide-up" style="top: 75%; left: 70%; transform: translate(-50%, 0); animation-delay: 0.7s; opacity: 0;">
      <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary shadow-sm mb-2 md:mb-3 hover-lift cursor-pointer">
        <span class="material-symbols-outlined text-2xl md:text-3xl">architecture</span>
      </div>
      <div class="space-y-0.5">
        <p class="font-body font-bold text-xs md:text-sm uppercase text-on-surface">Formas</p>
        <p class="font-body text-[8px] md:text-[10px] text-on-surface-variant font-medium">(Estructuración Nodal)</p>
      </div>
    </div>

    <!-- Bottom (180 deg) -->
    <div class="octagon-node text-center animate-slide-up" style="top: 90%; left: 47%; transform: translate(-50%, 0); animation-delay: 0.8s; opacity: 0;">
      <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary shadow-sm mb-2 md:mb-3 hover-lift cursor-pointer">
        <span class="material-symbols-outlined text-2xl md:text-3xl">eco</span>
      </div>
      <div class="space-y-0.5">
        <p class="font-body font-bold text-xs md:text-sm uppercase text-on-surface">Ecología</p>
        <p class="font-body text-[8px] md:text-[10px] text-on-surface-variant font-medium">(Espiritualidad)</p>
      </div>
    </div>

    <!-- Bottom Left (225 deg) -->
    <div class="octagon-node text-center animate-slide-up" style="top: 75%; left: 22%; transform: translate(-50%, 0); animation-delay: 0.9s; opacity: 0;">
      <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary shadow-sm mb-2 md:mb-3 hover-lift cursor-pointer">
        <span class="material-symbols-outlined text-2xl md:text-3xl">settings_input_component</span>
      </div>
      <div class="space-y-0.5">
        <p class="font-body font-bold text-xs md:text-sm uppercase text-on-surface">Medios</p>
        <p class="font-body text-[8px] md:text-[10px] text-on-surface-variant font-medium">(Instrumentos domésticos)</p>
      </div>
    </div>

    <!-- Left (270 deg) -->
    <div class="octagon-node text-center animate-slide-up" style="top: 45%; left: 13%; transform: translate(-50%, -50%); animation-delay: 1.0s; opacity: 0;">
      <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary shadow-sm mb-2 md:mb-3 hover-lift cursor-pointer">
        <span class="material-symbols-outlined text-2xl md:text-3xl">groups</span>
      </div>
      <div class="space-y-0.5">
        <p class="font-body font-bold text-xs md:text-sm uppercase text-on-surface">Sociedad</p>
        <p class="font-body text-[8px] md:text-[10px] text-on-surface-variant font-medium">(Comunicación Sacra)</p>
      </div>
    </div>

    <!-- Top Left (315 deg) -->
    <div class="octagon-node text-center animate-slide-up" style="top: 15%; left: 22%; transform: translate(-50%, 0); animation-delay: 1.1s; opacity: 0;">
      <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl bg-surface-container-highest flex items-center justify-center text-primary shadow-sm mb-2 md:mb-3 hover-lift cursor-pointer">
        <span class="material-symbols-outlined text-2xl md:text-3xl">bolt</span>
      </div>
      <div class="space-y-0.5">
        <p class="font-body font-bold text-xs md:text-sm uppercase text-on-surface">Fuerzas</p>
        <p class="font-body text-[8px] md:text-[10px] text-on-surface-variant font-medium">(Nodos Tributarios)</p>
      </div>
    </div>
  </main>

  <!-- Analysis Section -->
  <section class="w-full max-w-7xl mx-auto space-y-8 mb-12">
    <div class="flex items-end justify-between border-b border-outline-variant/30 pb-6 animate-slide-up" style="animation-delay: 1.2s; opacity: 0;">
      <div class="space-y-1">
        <h2 class="font-body text-2xl font-bold text-primary">Análisis de Nodos</h2>
        <p class="text-on-surface-variant text-sm">Interacciones dialécticas entre dimensiones sistémicas</p>
      </div>
      <div class="hidden md:flex gap-2">
        <span class="px-3 py-1 rounded-full bg-primary-fixed text-on-primary-fixed text-[10px] font-bold uppercase tracking-wider">Activo: Nodal</span>
        <span class="px-3 py-1 rounded-full bg-surface-container-high text-on-surface-variant text-[10px] font-bold uppercase tracking-wider">Flujo: Estático</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Analysis Card 1 -->
      <div class="bg-surface-container-lowest p-6 md:p-8 rounded-xl border-l-4 border-primary transition-all hover:translate-y-[-4px] hover:shadow-lg group animate-slide-up" style="animation-delay: 1.3s; opacity: 0;">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">history_edu</span>
          <div class="h-px flex-1 bg-outline-variant/20"></div>
          <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">eco</span>
        </div>
        <h3 class="font-body font-bold text-on-surface mb-2">Historia x Ecología</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed">
          La trascendencia histórica se manifiesta como una forma de espiritualidad ecológica, donde el tiempo no es lineal sino un ciclo de renovación de recursos simbólicos.
        </p>
      </div>

      <!-- Analysis Card 2 -->
      <div class="bg-surface-container-lowest p-6 md:p-8 rounded-xl border-l-4 border-secondary transition-all hover:translate-y-[-4px] hover:shadow-lg group animate-slide-up" style="animation-delay: 1.4s; opacity: 0;">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">psychology</span>
          <div class="h-px flex-1 bg-outline-variant/20"></div>
          <span class="material-symbols-outlined text-tertiary" style="font-variation-settings: 'FILL' 1;">bolt</span>
        </div>
        <h3 class="font-body font-bold text-on-surface mb-2">Ideología x fuerzas</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed">
          Los nodos tributarios alimentan la divinidad ideológica a través de la redirección de energías sociales hacia estructuras de creencia centralizadas.
        </p>
      </div>

      <!-- Analysis Card 3 -->
      <div class="bg-surface-container-lowest p-6 md:p-8 rounded-xl border-l-4 border-tertiary transition-all hover:translate-y-[-4px] hover:shadow-lg group animate-slide-up" style="animation-delay: 1.5s; opacity: 0;">
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-on-surface" style="font-variation-settings: 'FILL' 1;">architecture</span>
          <div class="h-px flex-1 bg-outline-variant/20"></div>
          <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">settings_input_component</span>
        </div>
        <h3 class="font-body font-bold text-on-surface mb-2">Formas x Medios</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed">
          La estructuración nodal define los instrumentos domésticos, convirtiendo el espacio cotidiano en una extensión geométrica del sistema cultural.
        </p>
      </div>
    </div>
  </section>

  <!-- Metric Section -->
  <section class="w-full max-w-7xl mx-auto mt-8 md:mt-12 grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 animate-slide-up" style="animation-delay: 1.6s; opacity: 0;">
    <div class="text-center p-4 md:p-6 bg-surface-container-low rounded-xl">
      <span class="block text-2xl md:text-3xl font-body font-extrabold text-primary mb-1">0.84</span>
      <span class="text-[8px] md:text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Coeficiente Nodal</span>
    </div>
    <div class="text-center p-4 md:p-6 bg-surface-container-low rounded-xl">
      <span class="block text-2xl md:text-3xl font-body font-extrabold text-primary mb-1">12.4k</span>
      <span class="text-[8px] md:text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Vectores Tributarios</span>
    </div>
    <div class="text-center p-4 md:p-6 bg-surface-container-low rounded-xl">
      <span class="block text-2xl md:text-3xl font-body font-extrabold text-primary mb-1">Σ9.2</span>
      <span class="text-[8px] md:text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Índice Sacro</span>
    </div>
    <div class="text-center p-4 md:p-6 bg-surface-container-low rounded-xl">
      <span class="block text-2xl md:text-3xl font-body font-extrabold text-primary mb-1">∞</span>
      <span class="text-[8px] md:text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Trascendencia</span>
    </div>
  </section>

  <PageNav
    prev={{ href: "/simbiosis-economica", label: "Simbiosis", sublabel: "Económica" }}
    next={{ href: "/sintesis-paradigma-cibernetico", label: "Síntesis", sublabel: "Cibernética" }}
  />

  <style>
    .octagon-node {
      position: absolute;
      z-index: 10;
    }
    .hover-lift {
      transition: all 0.3s ease;
      cursor: pointer;
    }
    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px -4px rgba(0, 0, 0, 0.15);
    }
  </style>
</Layout>
