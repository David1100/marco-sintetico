---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";

const blocks = [
  {
    title: "EL RESICLAJE DE LO RESIDUAL",
    indicatorW: "W = Energia",
    indicatorR: "R = Residuo",
    centerImage: "/images/reciclaje-residual/biomasa_pina.png",
    centerAlt: "Fruta de piña madura",
    satellites: [
      {
        name: "Pulpa",
        sublabel: "Fruta Deshidratada",
        image: "/images/reciclaje-residual/pulpa_fruta.png",
      },
      {
        name: "Jugo",
        sublabel: "Líquidos Alimenticios",
        image: "/images/reciclaje-residual/jugos.png",
      },
      {
        name: "Cáscara",
        sublabel: "Desperdicio Orgánico",
        image: "/images/reciclaje-residual/desperdicio_organico.png",
      },
      {
        name: "Follaje",
        sublabel: "Desperdicio Vegetal",
        image: "/images/reciclaje-residual/desperdicio_vegetal.png",
      },
      {
        name: "Fibras",
        sublabel: "Industriales",
        image: "/images/reciclaje-residual/pulpa_fruta.png",
      },
    ],
  }
];
---

<Layout title="Reciclaje de lo Residual - Bioprocesamiento Circular">
  <div class="flex gap-4 glass-card rounded-[2rem] p-6 md:p-8">

  <div class="flex flex-col gap-8 md:gap-12">
    {
      blocks.map((block) => (
        <section class="">
          <h1 class="text-2xl md:text-4xl font-body font-extrabold text-primary text-center mb-6">
            {block.title}
          </h1>

          <div class="flex flex-col gap-6">
            {/* Indicadores W y R */}
            <div class="flex justify-center gap-8">
              <span class="text-secondary font-body font-bold">{block.indicatorW}</span>
              <span class="text-tertiary font-body font-bold">{block.indicatorR}</span>
            </div>

            {/* Gráfico Circular con imagen central y satélites flotando */}
            <div class="relative w-full aspect-square max-w-lg mx-auto">
              {/* SVG Circle + Lines */}
              <svg
                class="absolute inset-0 w-full h-full pointer-events-none"
                viewBox="0 0 400 400"
                preserveAspectRatio="xMidYMid meet"
              >
                <defs>
                  <marker id="arrow-ccw" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
                    <path d="M4,1 L7,4 L4,7 L2,4 Z" fill="var(--color-secondary)" />
                  </marker>
                </defs>
                <circle cx="200" cy="200" r="170" fill="none" stroke="var(--color-outline-variant)" stroke-width="1" stroke-dasharray="4" opacity="0.5" />
                <path d="M200,70 A130,130 0 0,0 70,200" fill="none" stroke="var(--color-primary)" stroke-width="1.5" opacity="0.8" marker-end="url(#arrow-ccw)" />
                <path d="M70,200 A130,130 0 0,0 200,330" fill="none" stroke="var(--color-primary)" stroke-width="1.5" opacity="0.8" marker-end="url(#arrow-ccw)" />
                <path d="M200,330 A130,130 0 0,0 330,200" fill="none" stroke="var(--color-primary)" stroke-width="1.5" opacity="0.8" marker-end="url(#arrow-ccw)" />
                <path d="M330,200 A130,130 0 0,0 200,70" fill="none" stroke="var(--color-primary)" stroke-width="1.5" opacity="0.8" marker-end="url(#arrow-ccw)" />
                <text x="130" y="100" fill="var(--color-secondary)" font-size="14" font-weight="bold">W</text>
                <text x="260" y="100" fill="var(--color-secondary)" font-size="14" font-weight="bold">W</text>
                <text x="80" y="205" fill="var(--color-secondary)" font-size="14" font-weight="bold">W</text>
                <text x="310" y="205" fill="var(--color-secondary)" font-size="14" font-weight="bold">W</text>
                <text x="200" y="320" fill="var(--color-secondary)" font-size="14" font-weight="bold">W</text>
                <text x="200" y="50" fill="var(--color-secondary)" font-size="14" font-weight="bold">W</text>
                <text x="310" y="70" fill="var(--color-tertiary)" font-size="14" font-weight="bold">R</text>
                <text x="60" y="70" fill="var(--color-tertiary)" font-size="14" font-weight="bold">R</text>
                <text x="190" y="10" fill="var(--color-tertiary)" font-size="14" font-weight="bold">R</text>
                <text x="20" y="270" fill="var(--color-tertiary)" font-size="14" font-weight="bold">R</text>
                <text x="350" y="270" fill="var(--color-tertiary)" font-size="14" font-weight="bold">R</text>
              </svg>

              {/* Nodo Central */}
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-28 h-28 md:w-36 md:h-36 rounded-full overflow-hidden border-4 border-surface-container-lowest shadow-xl">
                <img
                  alt={block.centerAlt}
                  src={block.centerImage}
                  class="w-full h-full object-cover"
                />
              </div>

              {/* Satélites: 1 arriba, 2 laterales superiores, 2 laterales inferiores */}
              {/* 0: Pulpa - arriba (top center) */}
              <div class="absolute top-[5%] left-1/2 -translate-x-1/2 animate-float" style="animation-delay: 0.1s;">
                <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden shadow-lg border-2 border-surface-container-lowest">
                  <img src={block.satellites[0].image} alt={block.satellites[0].name} class="w-full h-full object-cover" />
                </div>
                <p class="mt-1 text-center text-xs font-body font-bold text-primary">{block.satellites[0].name}</p>
                <p class="text-center text-[9px] text-on-surface-variant font-body uppercase">{block.satellites[0].sublabel}</p>
              </div>

              {/* 1: Jugo - lateral superior derecho */}
              <div class="absolute top-[20%] right-[8%] animate-float" style="animation-delay: 0.2s;">
                <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden shadow-lg border-2 border-surface-container-lowest">
                  <img src={block.satellites[1].image} alt={block.satellites[1].name} class="w-full h-full object-cover" />
                </div>
                <p class="mt-1 text-center text-xs font-body font-bold text-primary">{block.satellites[1].name}</p>
                <p class="text-center text-[9px] text-on-surface-variant font-body uppercase">{block.satellites[1].sublabel}</p>
              </div>

              {/* 4: Fibras - lateral superior izquierdo */}
              <div class="absolute top-[20%] left-[8%] animate-float" style="animation-delay: 0.3s;">
                <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden shadow-lg border-2 border-surface-container-lowest">
                  <img src={block.satellites[4].image} alt={block.satellites[4].name} class="w-full h-full object-cover" />
                </div>
                <p class="mt-1 text-center text-xs font-body font-bold text-primary">{block.satellites[4].name}</p>
                <p class="text-center text-[9px] text-on-surface-variant font-body uppercase">{block.satellites[4].sublabel}</p>
              </div>

              {/* 2: Cáscara - lateral inferior derecho */}
              <div class="absolute bottom-[20%] right-[8%] animate-float" style="animation-delay: 0.4s;">
                <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden shadow-lg border-2 border-surface-container-lowest">
                  <img src={block.satellites[2].image} alt={block.satellites[2].name} class="w-full h-full object-cover" />
                </div>
                <p class="mt-1 text-center text-xs font-body font-bold text-primary">{block.satellites[2].name}</p>
                <p class="text-center text-[9px] text-on-surface-variant font-body uppercase">{block.satellites[2].sublabel}</p>
              </div>

              {/* 3: Follaje - lateral inferior izquierdo */}
              <div class="absolute bottom-[20%] left-[8%] animate-float" style="animation-delay: 0.5s;">
                <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden shadow-lg border-2 border-surface-container-lowest">
                  <img src={block.satellites[3].image} alt={block.satellites[3].name} class="w-full h-full object-cover" />
                </div>
                <p class="mt-1 text-center text-xs font-body font-bold text-primary">{block.satellites[3].name}</p>
                <p class="text-center text-[9px] text-on-surface-variant font-body uppercase">{block.satellites[3].sublabel}</p>
              </div>
            </div>
          </div>
        </section>
      ))
    }
  </div>
  <div class="flex flex-col gap-4 justify-center">
    <h1>QUIMICOS</h1>
    <h1>FARMACEUTICOS</h1>
    <h1>ALIMENTOS</h1>
    <h1>-FRUTAS</h1>
    <h1>-VERDURAS</h1>
    <h1>-OTROS</h1>
  </div>
  </div>

  <PageNav
    prev={{ href: "/sobredeterminacion", label: "Sobredeterminación", sublabel: "Teoría" }}
    next={{ href: "/aptitud-trabajo", label: "Aptitud", sublabel: "Trabajo" }}
  />
</Layout>
