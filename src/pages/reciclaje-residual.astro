---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Reciclaje de lo Residual: Bioprocesamiento Circular">
  <!-- Editorial Header -->
  <section class="mb-12 md:mb-16 text-center md:text-left">
    <span class="inline-block py-1 px-3 bg-primary-fixed text-on-primary-fixed-variant rounded-full text-xs font-bold tracking-widest uppercase mb-4 font-body">Informe de Sostenibilidad Circular</span>
    <h1 class="font-body text-4xl md:text-6xl lg:text-7xl font-extrabold text-primary leading-none tracking-tight mb-6 animate-slide-up" style="animation-delay: 0s; opacity: 0;">
      Reciclaje de lo Residual: <br/><span class="text-secondary">Bioprocesamiento Circular</span>
    </h1>
    <p class="max-w-2xl text-on-surface-variant text-lg leading-relaxed animate-slide-up" style="animation-delay: 0.1s; opacity: 0;">
      Ecosistema técnico integrado para la valorización total de subproductos de la Ananas comosus, transformando el desperdicio en capital industrial de alto valor.
    </p>
  </section>

  <!-- Central Diagram Canvas -->
  <div class="relative w-full aspect-square md:aspect-video bg-surface-container rounded-[2rem] overflow-hidden shadow-sm mb-16">
    <!-- Background Decorative Elements -->
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] md:w-[800px] h-[600px] md:h-[800px] border-[1px] border-primary rounded-full"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[600px] h-[400px] md:h-[600px] border-[1px] border-outline-variant rounded-full"></div>
    </div>

    <!-- SVG Flow Lines -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewbox="0 0 1200 800">
      <path class="text-outline-variant" style="stroke-dasharray: 4;" d="M600,400 Q450,200 300,180" fill="none" stroke="currentColor" stroke-width="2"></path>
      <path class="text-outline-variant" style="stroke-dasharray: 4;" d="M600,400 Q800,200 950,250" fill="none" stroke="currentColor" stroke-width="2"></path>
      <path class="text-outline-variant" style="stroke-dasharray: 4;" d="M600,400 Q800,600 900,650" fill="none" stroke="currentColor" stroke-width="2"></path>
      <path class="text-outline-variant" style="stroke-dasharray: 4;" d="M600,400 Q400,650 250,600" fill="none" stroke="currentColor" stroke-width="2"></path>
      <path class="text-outline-variant" style="stroke-dasharray: 4;" d="M600,400 Q300,400 200,400" fill="none" stroke="currentColor" stroke-width="2"></path>
      <!-- Energy (W) and Waste (R) Indicators -->
      <g class="font-body text-[10px] font-bold">
        <circle class="fill-secondary" cx="450" cy="300" r="12"></circle>
        <text fill="white" x="446" y="304">W</text>
        <circle class="fill-tertiary" cx="750" cy="300" r="12"></circle>
        <text fill="white" x="746" y="304">R</text>
        <circle class="fill-secondary" cx="750" cy="550" r="12"></circle>
        <text fill="white" x="746" y="554">W</text>
        <circle class="fill-tertiary" cx="400" cy="550" r="12"></circle>
        <text fill="white" x="396" y="554">R</text>
      </g>
    </svg>

    <!-- Central Node (The Pineapple) -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20 flex flex-col items-center animate-slide-up" style="animation-delay: 0.2s; opacity: 0;">
      <div class="w-36 h-36 md:w-48 md:h-48 lg:w-64 lg:h-64 rounded-full overflow-hidden border-4 border-surface-container-lowest shadow-2xl">
        <img alt="Fruta de piña madura" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBuuZa554ew0UDN4-M4v4SVfWaQgaBAYkHAF9dLcv5UHdj364RZgGZPLNheNsIPDWh-VzvWs5xvJkZEUJnq-IYr5zJJbUaZLEJDQn6RuWQ5IDJlxjgRsvH5hggvx6NHKqIHHNVqIn4Zwxv75fF10ucO_s4gfx0xQO60M59hVt7AFtAmtmUN_BEtZyvMqoFYLT0rU-6noNc4Jp6wi33e65d8Z2thHCVjUIwCzBKnQ1nKgZtpLTrVY-bohtsFOjfB25Scykg0cakAxU7D"/>
      </div>
      <div class="mt-3 md:mt-4 glass-card px-4 md:px-6 py-2 rounded-full border border-outline-variant/15">
        <span class="font-body font-bold text-primary text-sm md:text-base tracking-tight">Biomasa Primaria (Piña)</span>
      </div>
    </div>

    <!-- Satellite Nodes -->
    <!-- 1. Pulpa -->
    <div class="absolute top-[12%] left-[15%] md:left-[20%] group animate-slide-up" style="animation-delay: 0.3s; opacity: 0;">
      <div class="w-24 h-24 md:w-32 md:h-32 rounded-xl overflow-hidden shadow-lg transform group-hover:scale-105 transition-transform">
        <img alt="Pulpa deshidratada" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCYBcj1dZ74NBATBr2bXrcnMychvk6AXk7vJHWyt494pmn2bLz0m_jle4YS106TPwkSbWr-w9uq2mp4M5rZFWhIkTIocGKqNGszauEYBN5hLR9wokkoW-LAulKOSNidaFaqVnl9gfWM4sxMfbshZSBHalM_tnVs873orp29N0JNy8-GCCQ0igjjSKR6hVu-T5nUoenI-y3ETFnyJ3UQFwhO6nD1eMBvfP2vP3JwfSdxCXW_FSDDH0stAPdMZWuWVYCjVY_53ERd_CHa"/>
      </div>
      <div class="mt-2 text-center">
        <p class="font-body font-bold text-primary-container text-sm">Pulpa</p>
        <p class="text-[10px] text-on-surface-variant font-body uppercase tracking-widest">Fruta Deshidratada</p>
      </div>
    </div>

    <!-- 2. Jugo -->
    <div class="absolute top-[15%] right-[10%] md:right-[15%] group animate-slide-up" style="animation-delay: 0.4s; opacity: 0;">
      <div class="w-24 h-24 md:w-32 md:h-32 rounded-xl overflow-hidden shadow-lg transform group-hover:scale-105 transition-transform">
        <img alt="Zumo de piña fresco" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBB8pG9GhXurpMPZxWDF5BNwAl3cT0WTMdLwQx1cbJdfG_l45DHpvLFBURqdhK7KB82LWZtr8ghQj9DB6YX18CHkMu_TzbI2XuTZxUiT8GDK7j3jwqX4b7LeyWD3CZ974eKegYbrEAf2kJxkFA-sZCttaUPzEHde9fShsYiolG8YXwS1dEMOkC6d9K1pAquTg06rvppoRcVLz3-6IoGGaoCMN_I8UBYJ6hdHH6KpsPFDFuwrwHO9Zz3g6n8a1Wso8qCKxZCX9Ic-UEG"/>
      </div>
      <div class="mt-2 text-center">
        <p class="font-body font-bold text-primary-container text-sm">Jugo</p>
        <p class="text-[10px] text-on-surface-variant font-body uppercase tracking-widest">Líquidos Alimenticios</p>
      </div>
    </div>

    <!-- 3. Cáscara -->
    <div class="absolute bottom-[8%] right-[15%] md:right-[20%] group animate-slide-up" style="animation-delay: 0.5s; opacity: 0;">
      <div class="w-24 h-24 md:w-32 md:h-32 rounded-xl overflow-hidden shadow-lg transform group-hover:scale-105 transition-transform">
        <img alt="Cáscara de piña" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDumGlVYP_flhQYVsHhx4GpYUcsraQWxjFbnVa4D_bPwhsAErLqzruXxD0Oum4oVVbaRUVCE6RbepMTNxgtobg_PJ7lgGminPdB3M95CA0nfhQxuWRPZJyi16AH746LViKWs_oSY99QHiXazSGKKRhcXtYQzWamd2I4Xb-qsYME6rl_71zBDG-CBvbx-ETz4uQ4Xkr96iU0_XXY_v2l7URWLX0fFDZsZhJj2Tomivc9pHKGCks6PfvrTxSWh9tQKBJowhUt7GZtHvxP"/>
      </div>
      <div class="mt-2 text-center">
        <p class="font-body font-bold text-primary-container text-sm">Cáscara</p>
        <p class="text-[10px] text-on-surface-variant font-body uppercase tracking-widest">Desperdicio Orgánico</p>
      </div>
    </div>

    <!-- 4. Follaje -->
    <div class="absolute bottom-[8%] left-[8%] md:left-[16%] group animate-slide-up" style="animation-delay: 0.6s; opacity: 0;">
      <div class="w-24 h-24 md:w-32 md:h-32 rounded-xl overflow-hidden shadow-lg transform group-hover:scale-105 transition-transform">
        <img alt="Hojas de piña verdes" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAcTrVtEre8SNdZBmzovL0DF6IFT-5YRdQyYnrtHRzCqcNt5HFSaPgTct8EmzuGUIAKMrZEhH3ip4W5NOZd9kGmqcqT_oNdRmqSnkvOIqebpXjtTPsNhgDkSNfi0SgfpmrocFSZ9H9rOAqx9_yEqB80Iv2vMDSxJbAQ0bIkEXdrBkWR3zZTxBr6xm5JDjS_dxYXxQNGTY93MUPXJQvM5EaGPI6WT3Rpgo7buR7OoHga3dN8CXrR-zI_WMioXK8IVyjwXcM6LOUFWwd5"/>
      </div>
      <div class="mt-2 text-center">
        <p class="font-body font-bold text-primary-container text-sm">Follaje</p>
        <p class="text-[10px] text-on-surface-variant font-body uppercase tracking-widest">Desperdicio Vegetal</p>
      </div>
    </div>

    <!-- 5. Fibras -->
    <div class="absolute top-[38%] left-[3%] md:left-[12%] group animate-slide-up" style="animation-delay: 0.7s; opacity: 0;">
      <div class="w-24 h-24 md:w-32 md:h-32 rounded-xl overflow-hidden shadow-lg transform group-hover:scale-105 transition-transform">
        <img alt="Fibras industriales extraídas" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCxVj4RhD-IwfXjSkyaCgGhPaXIx07a_BeF-BaqUVAtBx7kQQEOjZ5KlVPM-biUXX6ja3r8kYN2BlIi1KbN0iMXJ_pEqffjnC9UEKQGbgCFZ-dr1JpJddJX1EF947w1A3wbAP-svykTFYQsHbIktHr5-Q4SCmk0BITfQnrh-gZ7DW2FpuAciexQ08pTCbZ6vSd7MOjo1Wa14G7dF0ER_zPbB3lVbhcFitIKHVvZ79s6i7tKMuudZ87x1MUCa3BvFzg6psxI3FMyK4Bw"/>
      </div>
      <div class="mt-2 text-center">
        <p class="font-body font-bold text-primary-container text-sm">Fibras</p>
        <p class="text-[10px] text-on-surface-variant font-body uppercase tracking-widest">Industriales / Textiles</p>
      </div>
    </div>
  </div>

  <!-- Industrial Applications Bento Grid -->
  <section class="mb-12">
    <div class="flex flex-col md:flex-row items-end justify-between mb-8 gap-4 animate-slide-up" style="animation-delay: 0.8s; opacity: 0;">
      <div>
        <h2 class="font-body text-2xl md:text-3xl font-bold text-primary mb-2">Transformación Industrial</h2>
        <p class="text-on-surface-variant font-body">Sectores de aplicación final del bioprocesamiento circular.</p>
      </div>
      <div class="flex gap-4">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-secondary"></span>
          <span class="text-xs font-body uppercase tracking-tighter">Energía (W)</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-tertiary"></span>
          <span class="text-xs font-body uppercase tracking-tighter">Recursos (R)</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Químico/Farma -->
      <div class="glass-card p-6 md:p-8 rounded-[2rem] flex flex-col gap-6 group hover:bg-white transition-colors animate-slide-up" style="animation-delay: 0.9s; opacity: 0;">
        <div class="w-12 h-12 rounded-full bg-primary-fixed flex items-center justify-center">
          <span class="material-symbols-outlined text-primary-container">science</span>
        </div>
        <div>
          <h3 class="font-body text-xl font-bold mb-3 text-primary">Química / Farmacéutica</h3>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Extracción de Bromelina</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Bio-plásticos a partir de almidón</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Solventes orgánicos</li>
          </ul>
        </div>
      </div>

      <!-- Alimentaria -->
      <div class="glass-card p-6 md:p-8 rounded-[2rem] flex flex-col gap-6 group hover:bg-white transition-colors animate-slide-up" style="animation-delay: 1s; opacity: 0;">
        <div class="w-12 h-12 rounded-full bg-secondary-fixed flex items-center justify-center">
          <span class="material-symbols-outlined text-on-secondary-fixed-variant">restaurant</span>
        </div>
        <div>
          <h3 class="font-body text-xl font-bold mb-3 text-secondary">Industria Alimentaria</h3>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Concentrados de néctar</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Snack-packs deshidratados</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Aditivos y saborizantes</li>
          </ul>
        </div>
      </div>

      <!-- Bio-Materiales -->
      <div class="glass-card p-6 md:p-8 rounded-[2rem] flex flex-col gap-6 group hover:bg-white transition-colors animate-slide-up" style="animation-delay: 1.1s; opacity: 0;">
        <div class="w-12 h-12 rounded-full bg-tertiary-fixed flex items-center justify-center">
          <span class="material-symbols-outlined text-on-tertiary-fixed-variant">eco</span>
        </div>
        <div>
          <h3 class="font-body text-xl font-bold mb-3 text-tertiary">Sostenibilidad Circular</h3>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Cuero vegetal (Piñatex)</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Compostaje de alta densidad</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-xs">check_circle</span> Fertilizantes líquidos</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <PageNav
    prev={{ href: "/sobredeterminacion", label: "Sobredeterminación", sublabel: "Cultura" }}
    next={{ href: "/", label: "Inicio", sublabel: "Dashboard" }}
  />
</Layout>