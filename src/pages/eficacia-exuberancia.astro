---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Eficacia de la Exuberancia - Marco Sintético">
  <!-- Title Section -->
  <header class="w-full max-w-7xl pt-8 pb-8 flex flex-col items-center text-center animate-fade-in">
    <h1 class="font-body font-extrabold text-4xl md:text-5xl text-primary tracking-tight mb-4">
      Eficacia de la Exuberancia
    </h1>
    <p class="font-body text-xl text-on-surface-variant max-w-2xl">
      Modelo de Transubstanciación Sistémica
    </p>
  </header>

  <!-- Main Diagram -->
  <main class="relative w-full max-w-5xl aspect-square md:aspect-[4/3] flex items-center justify-center p-4 md:p-8 mb-12">
    <!-- SVG Background -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-40" viewbox="0 0 1000 600">
      <rect class="bezier-connection" height="400" rx="40" width="500" x="250" y="100"></rect>
      <path class="bezier-connection" d="M500 50 L500 550"></path>
      <path class="bezier-connection" d="M100 300 L900 300"></path>
    </svg>

    <!-- Grid of Nodes -->
    <div class="relative grid grid-cols-2 grid-rows-2 gap-16 md:gap-32 z-10">
      <!-- Top Left: Creatividad -->
      <div class="flex flex-col items-center justify-center p-6 md:p-8 rounded-full bg-surface-container-lowest shadow-sm border border-outline-variant/15 w-36 h-36 md:w-48 md:h-48 text-center transition-all hover:shadow-md hover-lift animate-scale-in" style="animation-delay: 0.3s; opacity: 0;">
        <span class="material-symbols-outlined text-primary text-3xl md:text-4xl mb-2" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
        <span class="font-body font-bold text-primary tracking-tighter text-sm md:text-lg uppercase">Creatividad</span>
      </div>

      <!-- Top Right: Cibernética -->
      <div class="flex flex-col items-center justify-center p-6 md:p-8 rounded-full bg-surface-container-lowest shadow-sm border border-outline-variant/15 w-36 h-36 md:w-48 md:h-48 text-center transition-all hover:shadow-md hover-lift animate-scale-in" style="animation-delay: 0.4s; opacity: 0;">
        <span class="material-symbols-outlined text-primary text-3xl md:text-4xl mb-2" style="font-variation-settings: 'FILL' 1;">settings_input_component</span>
        <span class="font-body font-bold text-primary tracking-tighter text-sm md:text-lg uppercase">Cibernética</span>
      </div>

      <!-- Bottom Left: Pluralismo -->
      <div class="flex flex-col items-center justify-center p-6 md:p-8 rounded-full bg-surface-container-lowest shadow-sm border border-outline-variant/15 w-36 h-36 md:w-48 md:h-48 text-center transition-all hover:shadow-md hover-lift animate-scale-in" style="animation-delay: 0.5s; opacity: 0;">
        <span class="material-symbols-outlined text-primary text-3xl md:text-4xl mb-2" style="font-variation-settings: 'FILL' 1;">groups</span>
        <span class="font-body font-bold text-primary tracking-tighter text-sm md:text-lg uppercase">Pluralismo</span>
      </div>

      <!-- Bottom Right: Planificación -->
      <div class="flex flex-col items-center justify-center p-6 md:p-8 rounded-full bg-surface-container-lowest shadow-sm border border-outline-variant/15 w-36 h-36 md:w-48 md:h-48 text-center transition-all hover:shadow-md hover-lift animate-scale-in" style="animation-delay: 0.6s; opacity: 0;">
        <span class="material-symbols-outlined text-primary text-3xl md:text-4xl mb-2" style="font-variation-settings: 'FILL' 1;">account_tree</span>
        <span class="font-body font-bold text-primary tracking-tighter text-sm md:text-lg uppercase">Planificación</span>
      </div>

      <!-- Center: Núcleo -->
      <div class="absolute top-1/2 left-0 w-full flex items-center justify-center -translate-y-1/2 animate-scale-in" style="animation-delay: 0.3s; opacity: 0;">
        <div class="w-32 h-32 md:w-40 md:h-40 rounded-full bg-primary-container border-4 border-surface shadow-2xl flex flex-col items-center justify-center text-center p-3 md:p-4 relative overflow-hidden">
          <img alt="Systemic Balance" class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCmalqr8nIoZuGZMHrid4p-aBW9EO9DbY-mg0yInYlGf5GmsSuemmefJmTJeIGNEd72gml6W90Xovn40canlGydXCDRaPpbnfprrW2_AGgw217spSocmi1NFR-EV2mU-ZGoWPwcYWuVtJs1ZwO0xXOfBXe3XA0PEPbqxJ-MMzLPvu5csvDiSonWYsmbBeIavXe0oeJrD1jw4LxjylI3yxzKKRy2IVe0ixPHticsFve9snizzlvpixWjuONI31bUhjPt4H2xECT2zR-Y"/>
          <div class="relative z-10 flex flex-col items-center">
            <span class="material-symbols-outlined text-white text-2xl md:text-3xl mb-1 drop-shadow-md">sync</span>
            <div class="text-[8px] md:text-[10px] font-bold text-white uppercase tracking-widest leading-tight drop-shadow-md text-center">Regulación<br/>&amp;<br/>Alimentación</div>
            <div class="mt-1 md:mt-2 text-white font-body text-xs font-black drop-shadow-md">NÚCLEO</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Labels: Top -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-2 bg-surface-container-high px-3 md:px-4 py-1 rounded-full border border-outline-variant/20 shadow-sm flex items-center gap-2 animate-slide-up" style="animation-delay: 0.7s; opacity: 0;">
      <span class="material-symbols-outlined text-primary text-xs md:text-sm">sync_alt</span>
      <span class="text-[8px] md:text-[10px] font-bold text-primary uppercase tracking-[0.15em]">Transubstanciación</span>
      <div class="ml-1 md:ml-2 flex flex-col items-start leading-none">
        <span class="text-[6px] md:text-[8px] text-on-surface-variant font-bold">Optimización</span>
      </div>
    </div>

    <!-- Labels: Bottom -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-2 bg-surface-container-high px-3 md:px-4 py-1 rounded-full border border-outline-variant/20 shadow-sm flex items-center gap-2 animate-slide-up" style="animation-delay: 0.8s; opacity: 0;">
      <span class="material-symbols-outlined text-primary text-xs md:text-sm">sync_alt</span>
      <span class="text-[8px] md:text-[10px] font-bold text-primary uppercase tracking-[0.15em]">Transubstanciación</span>
      <div class="ml-1 md:ml-2 flex flex-col items-start leading-none">
        <span class="text-[6px] md:text-[8px] text-on-surface-variant font-bold">Expansión</span>
      </div>
    </div>

    <!-- Labels: Left -->
    <div class="absolute left-0 top-1/2 -translate-x-2 -translate-y-1/2 bg-surface-container-high px-2 py-3 md:py-4 rounded-full border border-outline-variant/20 shadow-sm flex flex-col items-center gap-2 animate-slide-up" style="animation-delay: 0.9s; opacity: 0;">
      <span class="material-symbols-outlined text-primary text-xs md:text-sm rotate-90">sync_alt</span>
      <div class="[writing-mode:vertical-lr] text-[8px] md:text-[10px] font-bold text-primary uppercase tracking-[0.15em]">Transubstanciación</div>
      <div class="flex flex-col items-center leading-none mt-1 md:mt-2">
        <span class="text-[6px] md:text-[8px] text-on-surface-variant font-bold">Combinación</span>
        <span class="text-[6px] md:text-[8px] text-on-surface-variant font-bold">Cooperación</span>
      </div>
    </div>

    <!-- Labels: Right -->
    <div class="absolute right-0 top-1/2 translate-x-2 -translate-y-1/2 bg-surface-container-high px-2 py-3 md:py-4 rounded-full border border-outline-variant/20 shadow-sm flex flex-col items-center gap-2 animate-slide-up" style="animation-delay: 1.0s; opacity: 0;">
      <span class="material-symbols-outlined text-primary text-xs md:text-sm rotate-90">sync_alt</span>
      <div class="[writing-mode:vertical-lr] text-[8px] md:text-[10px] font-bold text-primary uppercase tracking-[0.15em]">Transubstanciación</div>
      <div class="flex flex-col items-center leading-none mt-1 md:mt-2">
        <span class="text-[6px] md:text-[8px] text-on-surface-variant font-bold">Conservación</span>
        <span class="text-[6px] md:text-[8px] text-on-surface-variant font-bold">Extensión</span>
      </div>
    </div>
  </main>

  <!-- Footer Section -->
  <footer class="w-full max-w-6xl mx-auto mt-8 md:mt-12 grid grid-cols-1 lg:grid-cols-3 gap-8 md:gap-12 items-end border-t border-outline-variant/30 pt-8 md:pt-12 animate-slide-up" style="animation-delay: 1.1s; opacity: 0;">
    <div class="flex flex-col gap-2">
      <span class="text-secondary font-bold text-xs uppercase tracking-tighter">Foco Estructural</span>
      <p class="text-tertiary font-body text-lg md:text-xl leading-tight font-light italic">
        "Eficacia de la exuberancia y la eficiencia de la acumulación"
      </p>
    </div>
    <div class="flex flex-col items-center lg:items-start gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-[1px] bg-primary"></div>
        <span class="font-body font-extrabold text-primary text-xs md:text-sm tracking-widest uppercase">Articulación del Desarrollo</span>
      </div>
      <div class="text-on-surface-variant text-xs max-w-xs text-center lg:text-left">
        Configuración de los sistemas productivos bajo parámetros de crecimiento orgánico y técnico.
      </div>
    </div>
    <div class="flex flex-col items-center lg:items-end gap-4">
      <div class="flex items-center gap-3">
        <span class="font-body font-extrabold text-tertiary text-xs md:text-sm tracking-widest uppercase">Sub-articulación de la Democracia</span>
        <div class="w-10 h-[1px] bg-tertiary"></div>
      </div>
      <div class="text-on-surface-variant text-xs max-w-xs text-center lg:text-right">
        Mecanismos de integración social y flujo de información ciudadana en el núcleo regulador.
      </div>
    </div>
  </footer>

  <PageNav
    prev={{ href: "/creatividad", label: "Creatividad", sublabel: "Innovación" }}
    next={{ href: "/gestion-social", label: "Gestión", sublabel: "Social" }}
  />

  <style>
    .bezier-connection {
      stroke: #c4c6cd;
      stroke-width: 2;
      fill: none;
      stroke-dasharray: 4;
    }
    .hover-lift {
      transition: all 0.3s ease;
      cursor: pointer;
    }
    .hover-lift:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 16px -4px rgba(0, 0, 0, 0.15);
    }
  </style>
</Layout>
