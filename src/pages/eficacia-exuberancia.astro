---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Eficacia de la Exuberancia - Marco Sintético">
  <!-- Title Section -->
  <header
    class="w-full max-w-7xl pt-8 flex flex-col items-center text-center animate-fade-in"
  >
    <h1
      class="font-body font-extrabold text-4xl md:text-5xl text-primary tracking-tight"
    >
      Eficacia de la Exuberancia y Eficiencia de la Acumulación
    </h1>
  </header>

  <!-- Main Diagram: reorganizado como diagrama con flechas -->
  <main
    class="relative w-full aspect-square md:aspect-[4/3] flex items-center justify-center p-4"
  >
    <!-- SVG Arrow Connections -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none"
      viewBox="0 0 800 500"
    >
      <!-- Horizontal Arrow (top): Creatividad <-> Cibernética -->
      <defs>
        <marker
          id="arrow-left"
          markerWidth="10"
          markerHeight="10"
          refX="9"
          refY="3"
          orient="auto"
          markerUnits="strokeWidth"
        >
          <path d="M0,0 L0,6 L9,3 z" fill="currentColor" class="text-primary"
          ></path>
        </marker>
        <marker
          id="arrow-right"
          markerWidth="10"
          markerHeight="10"
          refX="9"
          refY="3"
          orient="auto"
          markerUnits="strokeWidth"
        >
          <path d="M0,0 L0,6 L9,3 z" fill="currentColor" class="text-primary"
          ></path>
        </marker>
      </defs>

      <!-- Top Arrow (Creatividad -> Cibernética) -->
      <path
        class="text-primary/40"
        d="M650,150 L150,150"
        stroke="currentColor"
        stroke-width="2"
        marker-end="url(#arrow-left)"></path>

      <!-- Bottom Arrow (Cibernética -> Creatividad) -->
      <path
        class="text-primary/40"
        d="M150,120 L650,120"
        stroke="currentColor"
        stroke-width="2"
        marker-end="url(#arrow-right)"></path>

      <!-- Bottom Arrow (Pluralismo <-> Planificación) -->
      <path
        class="text-tertiary/40"
        d="M150,350 L650,350"
        stroke="currentColor"
        stroke-width="2"
        marker-end="url(#arrow-left)"></path>
      <path
        class="text-tertiary/40"
        d="M650,380 L150,380"
        stroke="currentColor"
        stroke-width="2"
        marker-end="url(#arrow-right)"></path>

      <!-- Left Arrow (Pluralismo <-> Creatividad) -->
      <path
        class="text-secondary/40"
        d="M80,180 L80,320"
        stroke="currentColor"
        stroke-width="2"
        marker-end="url(#arrow-right)"></path>
      <path
        class="text-secondary/40"
        d="M120,320 L120,180"
        stroke="currentColor"
        stroke-width="2"
        marker-end="url(#arrow-left)"></path>

      <!-- Right Arrow (Planificación <-> Cibernética) -->
      <path
        class="text-secondary/40"
        d="M680,180 L680,320"
        stroke="currentColor"
        stroke-width="2"
        marker-end="url(#arrow-right)"></path>
      <path
        class="text-secondary/40"
        d="M720,320 L720,180"
        stroke="currentColor"
        stroke-width="2"
        marker-end="url(#arrow-left)"></path>
    </svg>

    <!-- Nodos en esquema 2x2 -->
    <div
      class="absolute inset-0 w-full h-full flex items-center justify-center"
    >
      <!-- Grid 2x2 con centro -->
      <div
        class="relative grid grid-cols-3 grid-rows-3 w-full aspect-square md:aspect-[4/3]"
      >
        <!-- Top Left: Creatividad -->
        <div
          class="flex flex-col items-center justify-center p-4 md:p-6 rounded-full bg-surface-container-lowest shadow-sm border border-outline-variant/15 w-28 h-28 md:w-36 md:h-36 text-center transition-all hover:shadow-md hover-lift animate-scale-in mt-46 ml-18"
          style="animation-delay: 0.3s; opacity: 0;"
        >
          <span
            class="material-symbols-outlined text-primary text-2xl md:text-3xl mb-1"
            style="font-variation-settings: 'FILL' 1;">auto_awesome</span
          >
          <span
            class="font-body font-bold text-primary tracking-tighter text-xs md:text-sm uppercase"
            >Creatividad</span
          >
        </div>

        <!-- Top Center: etiquetas de flecha superior -->
        <div class="flex flex-col items-center justify-center mt-63">
          <div class="flex flex-col items-center mt-1 gap-6">
            <span
              class="text-[6px] md:text-[9px] text-on-surface-variant font-bold"
              >Regulación</span
            >
            <span
              class="text-[6px] md:text-[10px] font-bold text-primary uppercase tracking-widest"
              >TRANSUBSTANCIACIÓN</span
            >
            <span
              class="text-[6px] md:text-[9px] text-on-surface-variant font-bold"
              >Optimización</span
            >
          </div>
        </div>

        <!-- Top Right: Cibernética -->
        <div
          class="flex flex-col items-center justify-center p-4 md:p-6 rounded-full bg-surface-container-lowest shadow-sm border border-outline-variant/15 w-28 h-28 md:w-36 md:h-36 text-center transition-all hover:shadow-md hover-lift animate-scale-in mt-46 ml-48"
          style="animation-delay: 0.4s; opacity: 0;"
        >
          <span
            class="material-symbols-outlined text-primary text-2xl md:text-3xl mb-1"
            style="font-variation-settings: 'FILL' 1;"
            >settings_input_component</span
          >
          <span
            class="font-body font-bold text-primary tracking-tighter text-xs md:text-sm uppercase"
            >Cibernética</span
          >
        </div>

        <!-- Center Left: etiquetas de flecha vertical izquierda -->
        <div
          class="flex flex-col justify-center items-center mt-1 gap-8 rotate-270 -ml-25"
        >
          <span
            class="text-[6px] md:text-[9px] text-on-surface-variant font-bold"
            >Combinación</span
          >
          <span
            class="text-[6px] md:text-[10px] font-bold text-primary uppercase tracking-widest whitespace-nowrap"
            >TRANSUBSTANCIACIÓN</span
          >
          <span
            class="text-[6px] md:text-[9px] text-on-surface-variant font-bold"
            >Cooperación</span
          >
        </div>

        <!-- Center: Núcleo -->
        <div
          class="flex items-center justify-center animate-scale-in"
          style="animation-delay: 0.3s; opacity: 0;"
        >
          <div
            class="w-60 h-60 rounded-full border-2 border-surface shadow-2xl flex items-center justify-center text-center p-1 md:p-2 relative overflow-hidden"
          >
            <img
              alt="Núcleo"
              src="/images/eficacia-exuberancia/image.png"
              class="w-full h-full object-contain rounded-full"
            />
          </div>
        </div>

        <!-- Center Right: etiquetas de flecha vertical derecha -->

        <div
          class="flex flex-col justify-center items-center ml-26 gap-8 rotate-270"
        >
          <span
            class="text-[6px] md:text-[9px] text-on-surface-variant font-bold"
            >Conservación</span
          >
          <span
            class="text-[6px] md:text-[10px] font-bold text-primary uppercase tracking-widest whitespace-nowrap"
            >TRANSUBSTANCIACIÓN</span
          >
          <span
            class="text-[6px] md:text-[9px] text-on-surface-variant font-bold"
            >Extensión</span
          >
        </div>

        <!-- Bottom Left: Pluralismo -->
        <div
          class="flex flex-col items-center justify-center p-4 md:p-6 rounded-full bg-surface-container-lowest shadow-sm border border-outline-variant/15 w-28 h-28 md:w-36 md:h-36 text-center transition-all hover:shadow-md hover-lift animate-scale-in -mt-9 ml-15"
          style="animation-delay: 0.5s; opacity: 0;"
        >
          <span
            class="material-symbols-outlined text-primary text-2xl md:text-3xl mb-1"
            style="font-variation-settings: 'FILL' 1;">groups</span
          >
          <span
            class="font-body font-bold text-primary tracking-tighter text-xs md:text-sm uppercase"
            >Pluralismo</span
          >
        </div>

        <!-- Bottom Center: etiquetas de flecha inferior -->
        <div class="flex flex-col items-center justify-center -mt-63">
          <div class="flex flex-col items-center mb-1 gap-6">
            <span
              class="text-[6px] md:text-[9px] text-on-surface-variant font-bold"
              >Expansión</span
            >
            <span
              class="text-[6px] md:text-[10px] font-bold text-primary uppercase tracking-widest"
              >TRANSUBSTANCIACIÓN</span
            >

            <span
              class="text-[6px] md:text-[9px] text-on-surface-variant font-bold"
              >Alimentación</span
            >
          </div>
        </div>

        <!-- Bottom Right: Planificación -->
        <div
          class="flex flex-col items-center justify-center p-4 md:p-6 rounded-full bg-surface-container-lowest shadow-sm border border-outline-variant/15 w-28 h-28 md:w-36 md:h-36 text-center transition-all hover:shadow-md hover-lift animate-scale-in ml-8 md:ml-46 -mt-8"
          style="animation-delay: 0.6s; opacity: 0;"
        >
          <span
            class="material-symbols-outlined text-primary text-2xl md:text-3xl mb-1"
            style="font-variation-settings: 'FILL' 1;">account_tree</span
          >
          <span
            class="font-body font-bold text-primary tracking-tighter text-xs md:text-sm uppercase"
            >Planificación</span
          >
        </div>
      </div>
    </div>
  </main>

  <!-- Footer Section -->
  <footer
    class="w-full animate-slide-up flex justify-between"
    style="animation-delay: 1.1s; opacity: 0;"
  >
    <div class="flex flex-col gap-2">
      <p
        class="text-tertiary font-body text-lg md:text-xl leading-tight font-light italic"
      >
        ARTICULACION DEL DESARROLLO
      </p>
    </div>
    <div class="flex flex-col gap-2">
      <p
        class="text-tertiary font-body text-lg md:text-xl leading-tight font-light italic"
      >
        SUB-ARTICULACION DE LA DEMOCRACIA
      </p>
    </div>
  </footer>

  <PageNav
    prev={{ href: "/capital-cultural", label: "Capital", sublabel: "Cultural" }}
    next={{
      href: "/sobredeterminacion-cultura",
      label: "Sobredeterminación",
      sublabel: "Cultura",
    }}
  />

  <style>
    .bezier-connection {
      stroke: #c4c6cd;
      stroke-width: 2;
      fill: none;
      stroke-dasharray: 4;
    }
    .hover-lift {
      transition: all 0.3s ease;
      cursor: pointer;
    }
    .hover-lift:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 16px -4px rgba(0, 0, 0, 0.15);
    }
  </style>
</Layout>
