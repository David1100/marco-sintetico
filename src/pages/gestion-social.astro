---
import Layout from "../layouts/Layout.astro";
import PageNav from "../components/PageNav.astro";
---

<Layout title="Gestión Social - Marco Sintético">
  <!-- Title Section -->
  <header class="w-full max-w-7xl pt-8 pb-8 flex flex-col items-center text-center animate-fade-in">
    <h1 class="font-body font-extrabold text-4xl md:text-5xl text-primary tracking-tight mb-4">
      Gestión Social
    </h1>
    <p class="font-body text-lg md:text-xl text-on-surface-variant max-w-2xl">
      Ciclo de Apropiación: Un marco metodológico para el equilibrio cívico y el desarrollo productivo
    </p>
  </header>

  <!-- Main Canvas -->
  <main class="w-full max-w-6xl mx-auto px-4 md:px-8 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 items-center">
      <!-- Technical Diagram Section (Left 7 cols) -->
      <div class="lg:col-span-7 relative min-h-[400px] md:min-h-[500px] flex items-center justify-center">
        <!-- Central Hub -->
        <div class="z-20 w-32 h-32 md:w-48 md:h-48 rounded-full bg-primary flex items-center justify-center shadow-xl border-4 md:border-8 border-surface-container-highest animate-scale-in" style="animation-delay: 0.3s; opacity: 0;">
          <span class="font-body text-lg md:text-3xl font-extrabold text-on-primary tracking-widest uppercase text-center">GESTIÓN</span>
        </div>

        <!-- Floating Nodes -->
        <!-- Top: Individual -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 md:w-64 text-center animate-slide-up" style="animation-delay: 0.4s; opacity: 0;">
          <div class="bg-surface-container-lowest p-4 md:p-6 rounded-xl shadow-sm border-b-4 border-primary-container">
            <h3 class="font-body text-xs md:text-sm font-bold text-primary mb-1 uppercase tracking-wider">Apropiación Individual</h3>
            <p class="font-body text-[10px] md:text-xs text-on-surface-variant">Apropiación personal de la dádiva</p>
          </div>
        </div>

        <!-- Right: Intellectual -->
        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-48 md:w-64 text-center animate-slide-up" style="animation-delay: 0.5s; opacity: 0;">
          <div class="bg-surface-container-lowest p-4 md:p-6 rounded-xl shadow-sm border-l-4 border-secondary">
            <h3 class="font-body text-xs md:text-sm font-bold text-secondary mb-1 uppercase tracking-wider">Apropiación Intelectual</h3>
            <p class="font-body text-[10px] md:text-xs text-on-surface-variant">Apropiación de la concreción invisible</p>
          </div>
        </div>

        <!-- Bottom: Private -->
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-48 md:w-64 text-center animate-slide-up" style="animation-delay: 0.6s; opacity: 0;">
          <div class="bg-surface-container-lowest p-4 md:p-6 rounded-xl shadow-sm border-t-4 border-tertiary">
            <h3 class="font-body text-xs md:text-sm font-bold text-tertiary mb-1 uppercase tracking-wider">Apropiación Privada</h3>
            <p class="font-body text-[10px] md:text-xs text-on-surface-variant">Apropiación íntima de la certeza</p>
          </div>
        </div>

        <!-- Left: Social -->
        <div class="absolute left-0 top-1/2 -translate-y-1/2 w-48 md:w-64 text-center animate-slide-up" style="animation-delay: 0.7s; opacity: 0;">
          <div class="bg-surface-container-lowest p-4 md:p-6 rounded-xl shadow-sm border-r-4 border-primary">
            <h3 class="font-body text-xs md:text-sm font-bold text-primary mb-1 uppercase tracking-wider">Apropiación Social</h3>
            <p class="font-body text-[10px] md:text-xs text-on-surface-variant">Apropiación ritual de la comunidad</p>
          </div>
        </div>

        <!-- Connecting Paths (SVG) -->
        <svg class="absolute inset-0 w-full h-full -z-10 pointer-events-none" viewbox="0 0 800 600">
          <circle cx="400" cy="300" fill="none" r="140" md:r="180" stroke="#dfe3e7" stroke-dasharray="8 8" stroke-width="1"></circle>
          <path class="node-connector" d="M 400 300 L 400 120"></path>
          <path class="node-connector" d="M 400 300 L 680 300"></path>
          <path class="node-connector" d="M 400 300 L 400 480"></path>
          <path class="node-connector" d="M 400 300 L 120 300"></path>
        </svg>
      </div>

      <!-- Community & Earth Section (Right 4 cols) -->
      <div class="lg:col-span-4 flex flex-col items-center">
        <div class="relative w-full max-w-[250px] md:max-w-[300px] aspect-square flex items-center justify-center p-4 md:p-8 animate-scale-in" style="animation-delay: 0.8s; opacity: 0;">
          <!-- Background Glow -->
          <div class="absolute inset-0 bg-primary-container rounded-full opacity-10 blur-3xl scale-90"></div>
          
          <!-- The Globe -->
          <div class="relative z-10 w-full aspect-square rounded-full shadow-2xl overflow-hidden border-4 border-white">
            <img alt="Earth from space" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDF1n3OirTpz60W-EvPPOu5z8K8-jm0pLoYt5gHwlpg3mJrTNks1zCYoUoFfCfsqZsf991l7d8Djf8xtiXIXlt2yLVJWgYRYev_NPPXQCHGVDlyD0EwLrBfpGx6gpGfTgpdtObyUYDaaitVlDxnMhXNZc6Z8OOTw-sJuaH-f5W8KzS_P6r1XsdEO2xN8Jldz40QQdcfOMgykPpbsADofUWJUUcFEQOQJyzJO8wH2H35URHFE_POTp-79_fabXu04SMd-jtSCPF_WuZo"/>
          </div>

          <!-- Community Circle -->
          <div class="absolute inset-0 z-20 flex items-center justify-center">
            <div class="w-full h-full relative">
              <div class="absolute top-[10%] left-1/2 -translate-x-1/2 bg-white rounded-full p-1.5 md:p-2 shadow-lg">
                <span class="material-symbols-outlined text-primary text-lg md:text-xl">groups</span>
              </div>
              <div class="absolute bottom-[10%] left-1/2 -translate-x-1/2 bg-white rounded-full p-1.5 md:p-2 shadow-lg">
                <span class="material-symbols-outlined text-primary text-lg md:text-xl">groups</span>
              </div>
              <div class="absolute top-1/2 left-[10%] -translate-y-1/2 bg-white rounded-full p-1.5 md:p-2 shadow-lg">
                <span class="material-symbols-outlined text-primary text-lg md:text-xl">groups</span>
              </div>
              <div class="absolute top-1/2 right-[10%] -translate-y-1/2 bg-white rounded-full p-1.5 md:p-2 shadow-lg">
                <span class="material-symbols-outlined text-primary text-lg md:text-xl">groups</span>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-6 md:mt-8 text-center animate-slide-up" style="animation-delay: 0.9s; opacity: 0;">
          <div class="inline-flex items-center gap-2 md:gap-3 bg-primary py-2 md:py-3 px-6 md:px-8 rounded-full shadow-lg">
            <span class="material-symbols-outlined text-on-primary" style="font-variation-settings: 'FILL' 1;">diversity_3</span>
            <span class="font-body font-bold text-on-primary uppercase tracking-widest text-xs md:text-sm">Apropiación Social</span>
          </div>
          <p class="mt-3 md:mt-4 font-body text-xs md:text-sm text-on-surface-variant font-medium">(Ritual de la comunidad)</p>
        </div>
      </div>
    </div>
  </main>

  <!-- Detailed Footer / Technical Notes -->
  <footer class="w-full max-w-6xl mx-auto mt-8 md:mt-12 pt-8 md:pt-12 border-t border-outline-variant/30 animate-slide-up" style="animation-delay: 1.0s; opacity: 0;">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 mb-8 md:mb-12 px-4">
      <div>
        <h4 class="font-body text-xs font-extrabold text-primary mb-3 md:mb-4 uppercase tracking-tighter">Metodología</h4>
        <p class="text-xs md:text-sm text-on-surface-variant leading-relaxed">Este ciclo describe el proceso por el cual el capital intelectual se transforma en bienestar social tangible a través de la gestión de activos públicos y privados.</p>
      </div>
      <div>
        <h4 class="font-body text-xs font-extrabold text-primary mb-3 md:mb-4 uppercase tracking-tighter">Propósito</h4>
        <p class="text-xs md:text-sm text-on-surface-variant leading-relaxed">Establecer el equilibrio cívico necesario para que la productividad social sea sostenible y equitativa en entornos de alta complejidad.</p>
      </div>
      <div>
        <h4 class="font-body text-xs font-extrabold text-primary mb-3 md:mb-4 uppercase tracking-tighter">Contacto</h4>
        <p class="text-xs md:text-sm text-on-surface-variant leading-relaxed">gestionsocial@equilibriocivico.org<br/>Unidad de Desarrollo Productivo</p>
      </div>
      <div class="flex flex-col md:items-end justify-start">
        <span class="font-body font-bold text-primary text-lg md:text-xl tracking-tight">Gestión Social</span>
        <span class="text-[8px] md:text-[10px] text-on-surface-variant uppercase tracking-[0.2em] mt-1 font-semibold">Equilibrio Cívico</span>
      </div>
    </div>
  </footer>

  <PageNav
    prev={{ href: "/eficacia-exuberancia", label: "Eficacia", sublabel: "Exuberancia" }}
    next={{ href: "/simbiosis-economica", label: "Simbiosis", sublabel: "Económica" }}
  />

  <style>
    .node-connector {
      stroke: #c4c6cd;
      stroke-width: 2;
      fill: none;
    }
  </style>
</Layout>
